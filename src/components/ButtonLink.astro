---
interface Props { href: string; variant?: 'primary'|'secondary'; }
const { href, variant = 'primary' } = Astro.props;
---
<a href={href} class:list={['button', variant, variant === 'primary' && 'shine']} data-magnetic data-magnetic-strength="0.2"><span class="label"><slot /></span><span class="arrow" aria-hidden="true">→</span></a>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.15rem;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }

  .primary {
    background: var(--text-primary);
    color: var(--background);
  }

  .primary:hover {
    background: color-mix(in srgb, var(--text-primary) 85%, var(--background));
  }

  .secondary {
    border-color: var(--border-strong);
    color: var(--text-primary);
  }

  .secondary:hover {
    border-color: var(--text-primary);
  }

  .arrow {
    transition: transform 0.35s var(--ease-out);
  }

  .button:hover .arrow {
    transform: translateX(4px);
  }

  .label,
  .arrow {
    position: relative;
    z-index: 1;
    pointer-events: none;
  }
</style>
