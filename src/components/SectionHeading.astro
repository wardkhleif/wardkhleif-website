---
interface Props { eyebrow?: string; title: string; text?: string; }
const { eyebrow, title, text } = Astro.props;
---
<div class="section-heading">{eyebrow && <p class="eyebrow">{eyebrow}</p>}<h2>{title}</h2>{text && <p class="copy">{text}</p>}</div>
<style>.section-heading{max-width:43rem;margin-bottom:2rem}.eyebrow{color:var(--accent-bright);text-transform:uppercase;letter-spacing:.13em;font-size:.75rem;font-weight:720;margin-bottom:.65rem}.copy{color:var(--text-secondary);font-size:1.05rem;margin-top:.75rem}</style>
