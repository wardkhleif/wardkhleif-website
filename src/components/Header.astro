---
import Logo from './Logo.astro'; import ThemeToggle from './ThemeToggle.astro'; import { navigation, site } from '../data/site';
const path = Astro.url.pathname;
const active = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---
<header>
  <div class="shell nav-shell">
    <a class="logo-link" href="/"><Logo /></a>
    <nav id="primary-nav" aria-label="Primary navigation">
      {navigation.map((item) => <a href={item.href} aria-current={active(item.href) ? 'page' : undefined}>{item.label}</a>)}
    </nav>
    <div class="actions">
      {site.githubUrl && <a class="github" href={site.githubUrl} target="_blank" rel="noreferrer" aria-label="Ward Khleif on GitHub">GitHub</a>}
      <ThemeToggle />
      <button class="menu" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Open navigation menu"><span></span><span></span></button>
    </div>
  </div>
</header>
<style>
  header{position:sticky;top:0;z-index:20;background:color-mix(in srgb,var(--background) 76%,transparent);backdrop-filter:blur(22px) saturate(140%);border-bottom:1px solid transparent;animation:header-drop .7s cubic-bezier(.22,1,.36,1) both}.nav-shell{height:4.6rem;display:flex;align-items:center;justify-content:space-between}.logo-link{position:relative;z-index:2;text-decoration:none}nav{display:flex;gap:.4rem;padding:.24rem;border:1px solid var(--border);border-radius:.78rem;background:color-mix(in srgb,var(--surface) 50%,transparent)}nav a{padding:.46rem .75rem;color:var(--text-secondary);text-decoration:none;font-size:.9rem;border-radius:.55rem;position:relative}nav a:hover,nav a[aria-current="page"]{color:var(--text-primary);background:var(--surface)}nav a[aria-current="page"]:after{content:"";position:absolute;left:50%;bottom:-.28rem;width:.28rem;height:.28rem;border-radius:50%;background:var(--accent-bright);box-shadow:0 0 12px var(--accent-bright);transform:translateX(-50%)}.actions{display:flex;align-items:center;gap:.55rem}.github{font-size:.9rem}.menu{display:none;width:2.65rem;height:2.65rem;border:1px solid var(--border);border-radius:50%;background:var(--surface);padding:.7rem}.menu span{display:block;height:1.5px;background:var(--text-primary);margin:4px}@keyframes header-drop{from{opacity:0;transform:translateY(-16px)}to{opacity:1;transform:none}}
  @media(max-width:700px){.brand :global(span){display:none}.menu{display:block}nav{display:none;position:absolute;inset:4.6rem 0 auto;padding:1rem 1.25rem 1.4rem;background:var(--background);border-bottom:1px solid var(--border);flex-direction:column}nav.open{display:flex}nav a{font-size:1.05rem;padding:.8rem}.github{display:none}}
</style>
