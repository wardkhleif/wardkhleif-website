---
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
import { navigation, site } from '../data/site';
const path = Astro.url.pathname;
const active = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---

<header>
  <div class="shell nav-shell">
    <a class="logo-link" href="/"><Logo /></a>
    <nav id="primary-nav" aria-label="Primary navigation">
      {navigation.map(item => <a href={item.href} aria-current={active(item.href) ? 'page' : undefined}>{item.label}</a>)}
    </nav>
    <div class="actions">
      {site.githubUrl && <a class="github" href={site.githubUrl} target="_blank" rel="me noreferrer" data-magnetic data-magnetic-strength="0.3">GitHub</a>}
      <ThemeToggle />
      <button class="menu" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Open navigation menu"><span></span><span></span></button>
    </div>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--background) 82%, transparent);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
    transition: transform 0.55s var(--ease-out), border-color 0.4s var(--ease-out);
  }

  /* Only draw the divider once the page has actually moved under it. */
  header.is-stuck {
    border-bottom-color: var(--border);
  }

  header.is-hidden {
    transform: translateY(-101%);
  }

  /* The menu must never be stranded off-screen while it's open. */
  header:has(nav.open) {
    transform: none;
  }

  .nav-shell {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 4.25rem;
  }

  .logo-link {
    position: relative;
    z-index: 2;
    width: max-content;
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  nav a,
  .github {
    position: relative;
    color: var(--text-secondary);
    font-size: 0.88rem;
    font-weight: 400;
    text-decoration: none;
  }

  nav a:hover,
  .github:hover,
  nav a[aria-current="page"] {
    color: var(--text-primary);
  }

  /* A hairline, not a slab. */
  nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 0.4s var(--ease-out);
  }

  nav a:hover::after,
  nav a[aria-current="page"]::after {
    transform: scaleX(1);
  }

  .actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .menu {
    display: none;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.7rem;
    border: 1px solid var(--border);
    border-radius: 0.4rem;
    background: transparent;
  }

  .menu span {
    display: block;
    height: 1px;
    margin: 4px 0;
    background: var(--text-primary);
  }

  @media (max-width: 700px) {
    .nav-shell {
      display: flex;
      justify-content: space-between;
    }

    .brand :global(span) {
      display: none;
    }

    .menu {
      display: block;
    }

    nav {
      display: none;
      position: absolute;
      inset: 4.25rem 0 auto;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 1.25rem 1rem;
      background: var(--background);
      border-bottom: 1px solid var(--border);
    }

    nav.open {
      display: flex;
    }

    nav a {
      padding: 0.9rem 0;
      border-bottom: 1px solid var(--border);
      font-size: 1.05rem;
    }

    nav a::after {
      display: none;
    }

    .github {
      display: none;
    }
  }
</style>
