---
interface Props { type: 'photos'|'codes'|'automation'|'more'; }
const { type } = Astro.props;
---
<div class:list={['preview', type]} aria-hidden="true">
  {type === 'photos' && <><div class="phone"><span class="notch"></span><div class="photo"><i></i><b></b></div><div class="decisions"><span>×</span><span>↑</span><span>✓</span></div></div><div class="float-tag">On-device</div></>}
  {type === 'codes' && <><div class="browser"><div class="browser-top"><i></i><i></i><i></i></div><p>Verification code</p><strong>482 913</strong><span>Received just now</span></div><div class="float-tag">OAuth 2.0</div></>}
  {type === 'automation' && <><div class="nodes"><span>Schedule</span><i>→</i><span>Organize</span><i>→</i><span>Message</span></div></>}
  {type === 'more' && <div class="plus">+</div>}
</div>
<style>
  .preview{min-height:18rem;border-radius:1rem;position:relative;display:grid;place-items:center;overflow:hidden;background:radial-gradient(circle at 70% 20%,color-mix(in srgb,var(--card-accent) 24%,transparent),transparent 45%),var(--surface-elevated);border:1px solid var(--border)}.preview:before{content:"";position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:30px 30px;mask-image:linear-gradient(to bottom,black,transparent);opacity:.28}.phone{width:9rem;height:15rem;border-radius:1.5rem;padding:.8rem;background:#10151d;border:5px solid #28313c;box-shadow:0 25px 45px #0008;transform:rotate(4deg);z-index:1}.notch{display:block;width:2.8rem;height:.35rem;margin:0 auto .7rem;border-radius:2rem;background:#313b46}.photo{height:8.8rem;border-radius:.7rem;background:linear-gradient(145deg,#175f67,#52d6bd);position:relative;overflow:hidden}.photo i{position:absolute;width:4rem;height:4rem;border-radius:50%;background:#a7efe4;right:-.8rem;top:1rem}.photo b{position:absolute;bottom:0;border-style:solid;border-width:0 0 4.5rem 7.5rem;border-color:transparent transparent #13454f transparent}.decisions{display:flex;justify-content:space-around;margin-top:.7rem}.decisions span{display:grid;place-items:center;width:1.8rem;height:1.8rem;border-radius:50%;background:#222b35;color:white}.float-tag{position:absolute;right:10%;bottom:12%;z-index:2;padding:.55rem .75rem;border:1px solid var(--border);background:color-mix(in srgb,var(--surface) 85%,transparent);backdrop-filter:blur(10px);border-radius:.6rem;font-size:.75rem;color:var(--text-secondary)}.browser{width:min(80%,19rem);padding:1rem 1.2rem 1.3rem;border-radius:.8rem;background:var(--surface);border:1px solid var(--border);z-index:1;box-shadow:0 22px 45px #0005}.browser-top{display:flex;gap:.3rem;border-bottom:1px solid var(--border);padding-bottom:.8rem}.browser-top i{width:.45rem;height:.45rem;background:var(--text-secondary);opacity:.5;border-radius:50%}.browser p{color:var(--text-secondary);font-size:.75rem;margin:1.2rem 0 .35rem}.browser strong{font-size:2rem;letter-spacing:.14em}.browser>span{display:block;color:var(--text-secondary);font-size:.7rem;margin-top:.55rem}.nodes{display:flex;align-items:center;gap:.5rem;position:relative;z-index:1}.nodes span{padding:.75rem;border:1px solid var(--border);background:var(--surface);border-radius:.6rem;font-size:.75rem}.nodes i{font-style:normal;color:var(--card-accent)}.plus{font-size:5rem;color:var(--card-accent);font-weight:200;position:relative}.more{min-height:12rem}
</style>
