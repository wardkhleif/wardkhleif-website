---
import type { Project } from '../data/projects';
import ProductPreview from './ProductPreview.astro';

interface Props { project: Project; index: number; }
const { project, index } = Astro.props;

const href = project.detailUrl || undefined;
const label = String(index + 1).padStart(2, '0');
// The whole row is clickable when there's somewhere to go; otherwise it's a
// plain article so we don't ship an anchor that leads nowhere.
const Tag = href ? 'a' : 'div';
---

<article class="row" style={`--card-accent:${project.accent}`}>
  <Tag class="row-inner" href={href}>
    <div class="copy" data-stagger>
      <span class="index" aria-hidden="true">{label}</span>

      <h3 class="name">{project.name}</h3>
      {project.subtitle && <p class="subtitle">{project.subtitle}</p>}
      <p class="desc">{project.shortDescription}</p>

      <dl class="meta">
        <div><dt>Platform</dt><dd>{project.platform}</dd></div>
        <div><dt>Status</dt><dd><span class="dot" aria-hidden="true"></span>{project.status}</dd></div>
      </dl>

      {project.technologies.length > 0 && (
        <ul class="tech">{project.technologies.map((tech) => <li>{tech}</li>)}</ul>
      )}

      {href && <span class="cta">View project <span class="arrow" aria-hidden="true">→</span></span>}
    </div>

    <div class="visual" data-parallax="40">
      <div class="visual-inner" data-wipe data-spotlight>
        <ProductPreview type={project.preview} />
      </div>
    </div>
  </Tag>
</article>

<style>
  .row {
    border-top: 1px solid var(--border);
  }

  .row-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding-block: clamp(3rem, 6vw, 5rem);
    color: inherit;
    text-decoration: none;
  }

  .copy {
    max-width: 34rem;
  }

  .index {
    display: block;
    margin-bottom: 1.5rem;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
  }

  .name {
    margin: 0;
    font-size: clamp(1.9rem, 3.4vw, 2.9rem);
    letter-spacing: -0.036em;
    transition: color 0.35s var(--ease-out);
  }

  .subtitle {
    margin: 0.35rem 0 0;
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .desc {
    margin: 1.15rem 0 0;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2.25rem;
    margin: 1.75rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .meta dt {
    color: var(--text-tertiary);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .meta dd {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
  }

  .dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--card-accent);
  }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tech li {
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 0.35rem;
    color: var(--text-secondary);
    font-size: 0.78rem;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .arrow {
    transition: transform 0.35s var(--ease-out);
  }

  .visual {
    transform: translate3d(0, var(--parallax-y, 0), 0);
    will-change: transform;
  }

  /* Wipe lives on an inner wrapper so it can't fight the parallax transform
     on the parent. */
  .visual-inner {
    border-radius: 0.9rem;
    overflow: hidden;
  }

  /* Hover state — the project's own accent is the only colour that appears. */
  .row-inner:hover .name,
  .row-inner:focus-visible .name {
    color: var(--card-accent);
  }

  .row-inner:hover .arrow,
  .row-inner:focus-visible .arrow {
    transform: translateX(5px);
  }

  .row-inner :global(.preview) {
    transition: transform 0.7s var(--ease-out), border-color 0.4s var(--ease-out),
      box-shadow 0.5s var(--ease-out);
  }

  .row-inner:hover :global(.preview),
  .row-inner:focus-visible :global(.preview) {
    transform: scale(1.03);
    border-color: color-mix(in srgb, var(--card-accent) 45%, var(--border));
    box-shadow: 0 22px 55px color-mix(in srgb, var(--card-accent) 16%, transparent);
  }

  .row-inner .index,
  .row-inner .tech li {
    transition: color 0.35s var(--ease-out), border-color 0.35s var(--ease-out);
  }

  .row-inner:hover .index {
    color: var(--card-accent);
  }

  .row-inner:hover .tech li {
    border-color: color-mix(in srgb, var(--card-accent) 30%, var(--border));
  }

  /* Tablet — stack before the two columns get too cramped to read. */
  @media (max-width: 880px) {
    .row-inner {
      grid-template-columns: 1fr;
      gap: 2.25rem;
      padding-block: clamp(2.5rem, 8vw, 3.5rem);
    }

    .visual {
      order: -1;
      transform: none;
    }

    .copy {
      max-width: none;
    }
  }

  @media (max-width: 560px) {
    .index {
      margin-bottom: 1rem;
    }

    .meta {
      gap: 1.5rem;
      margin-top: 1.35rem;
      padding-top: 1.25rem;
    }

    .cta {
      margin-top: 1.5rem;
    }
  }

  /* Nothing to hover on touch — keep the resting state fully legible. */
  @media (hover: none) {
    .row-inner:hover :global(.preview) {
      transform: none;
      box-shadow: none;
    }
  }
</style>
