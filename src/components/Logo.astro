---
import Monogram from './Monogram.astro';
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---
<span class="brand" aria-label="Ward Khleif">
  <span class="mark"><Monogram size="2.35rem" /></span>
  {!compact && <span>Ward Khleif</span>}
</span>
<style>
  .brand{display:inline-flex;align-items:center;gap:.7rem;font-weight:720;letter-spacing:-.02em;color:var(--text-primary)}
  .mark{width:2.7rem;height:2.2rem;display:grid;place-items:center;flex:none;color:var(--text-primary)}
</style>
