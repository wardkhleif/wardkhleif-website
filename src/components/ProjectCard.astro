---
import type { Project } from '../data/projects'; import ProjectStatus from './ProjectStatus.astro'; import ProductPreview from './ProductPreview.astro';
interface Props { project: Project; }
const { project } = Astro.props;
const href = project.detailUrl || undefined;
---
<article class="project-card" style={`--card-accent:${project.accent}`}>
  <ProductPreview type={project.preview} />
  <div class="project-copy"><div class="meta"><span>{project.platform}</span><ProjectStatus status={project.status} /></div><h3>{project.name}</h3>{project.subtitle && <p class="subtitle">{project.subtitle}</p>}<p>{project.shortDescription}</p>{href && <a href={href}>Explore project <span aria-hidden="true">→</span></a>}</div>
</article>
<style>.project-card{display:grid;grid-template-columns:minmax(0,1.04fr) minmax(0,.96fr);gap:0;border:1px solid var(--border);border-radius:1.1rem;overflow:hidden;background:var(--surface);transition:transform .25s,border-color .25s}.project-card:hover{transform:translateY(-4px);border-color:color-mix(in srgb,var(--card-accent) 55%,var(--border))}.project-card :global(.preview){border:0;border-radius:0}.project-copy{padding:clamp(1.5rem,4vw,2.7rem);align-self:center}.meta{display:flex;align-items:center;justify-content:space-between;gap:1rem;color:var(--text-secondary);font-size:.78rem;text-transform:uppercase;letter-spacing:.08em}.project-copy h3{font-size:clamp(1.55rem,3vw,2.3rem);margin:1.2rem 0 .2rem}.subtitle{color:var(--card-accent)!important;font-weight:650;margin-top:0!important}.project-copy>p{color:var(--text-secondary);line-height:1.7;margin:1rem 0}.project-copy a{display:inline-flex;gap:.5rem;color:var(--text-primary);text-decoration:none;font-weight:650}.project-copy a span{color:var(--card-accent);transition:transform .2s}.project-copy a:hover span{transform:translateX(4px)}@media(max-width:720px){.project-card{grid-template-columns:1fr}.project-copy{padding:1.5rem}.meta{align-items:flex-start}.project-card :global(.preview){min-height:15rem}}</style>
