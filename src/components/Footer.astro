---
import Logo from './Logo.astro'; import { navigation, site } from '../data/site';
---
<footer>
  <div class="shell footer-grid">
    <div>
      <a href="/" class="footer-logo"><Logo /></a>
      <p>Computer science student</p>
    </div>
    <div class="footer-links">
      <nav aria-label="Footer navigation">
        {navigation.slice(1).map((item) => <a href={item.href}>{item.label}</a>)}
        <a href="/support">Support</a>
        <a href="/privacy">Privacy</a>
      </nav>
      {(site.githubUrl || site.linkedinUrl) && (
        <div>
          {site.githubUrl && <a href={site.githubUrl}>GitHub</a>}
          {site.linkedinUrl && <a href={site.linkedinUrl}>LinkedIn</a>}
        </div>
      )}
    </div>
  </div>
  <div class="shell copyright">© {new Date().getFullYear()} Ward Khleif</div>
</footer>

<style>
  footer {
    padding: clamp(3rem, 6vw, 4.5rem) 0 2rem;
    border-top: 1px solid var(--border);
  }

  .footer-grid {
    display: flex;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .footer-logo {
    text-decoration: none;
  }

  .footer-grid p {
    margin: 0.9rem 0 0;
    color: var(--text-secondary);
    font-size: 0.92rem;
  }

  .footer-links {
    display: flex;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .footer-links nav,
  .footer-links > div {
    display: grid;
    gap: 0.7rem;
    align-content: start;
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--text-primary);
  }

  .copyright {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    color: var(--text-tertiary);
    font-size: 0.82rem;
  }

  @media (max-width: 600px) {
    .footer-grid {
      flex-direction: column;
    }
  }
</style>
