---
import Logo from './Logo.astro'; import { navigation, site } from '../data/site';
---
<footer><div class="shell footer-grid"><div><a href="/" class="footer-logo"><Logo /></a><p>Computer science student</p><p class="care">A personal corner of the internet.</p></div><div class="footer-links"><nav aria-label="Footer navigation">{navigation.slice(1).map((item)=><a href={item.href}>{item.label}</a>)}<a href="/support">Support</a><a href="/privacy">Privacy</a></nav>{(site.githubUrl || site.linkedinUrl) && <div>{site.githubUrl && <a href={site.githubUrl}>GitHub</a>}{site.linkedinUrl && <a href={site.linkedinUrl}>LinkedIn</a>}</div>}</div></div><div class="shell copyright">© {new Date().getFullYear()} Ward Khleif</div></footer>
<style>
  footer{border-top:1px solid var(--border);padding:4rem 0 2rem;margin-top:6rem}.footer-grid{display:flex;justify-content:space-between;gap:2rem}.footer-logo{text-decoration:none}.footer-grid p{color:var(--text-secondary);margin:.75rem 0}.care{font-size:.9rem}.footer-links{display:flex;gap:3rem}.footer-links nav,.footer-links>div{display:grid;gap:.65rem}.footer-links a{color:var(--text-secondary);text-decoration:none}.footer-links a:hover{color:var(--text-primary)}.copyright{border-top:1px solid var(--border);margin-top:2.5rem;padding-top:1.25rem;color:var(--text-secondary);font-size:.85rem}@media(max-width:600px){.footer-grid{flex-direction:column}.footer-links{margin-top:1rem}}
</style>
