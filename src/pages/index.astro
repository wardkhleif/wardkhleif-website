---
import BaseLayout from '../layouts/BaseLayout.astro'; import ButtonLink from '../components/ButtonLink.astro'; import SectionHeading from '../components/SectionHeading.astro'; import ProjectCard from '../components/ProjectCard.astro'; import { projects } from '../data/projects';
---
<BaseLayout>
  <section class="hero"><div class="shell hero-grid"><div class="hero-copy"><p class="eyebrow">Independent Software Developer</p><h1>I build useful apps, browser extensions, and automation tools.</h1><p class="lead">I’m Ward Khleif. I design and develop focused digital products that solve real problems without unnecessary complexity.</p><div class="buttons"><ButtonLink href="/projects">Explore my work</ButtonLink><ButtonLink href="/about" variant="secondary">About me</ButtonLink></div></div><div class="hero-visual" aria-hidden="true"><div class="orbit one"></div><div class="orbit two"></div><div class="wk">WK</div><div class="tile ios"><i></i><span>iOS apps</span></div><div class="tile ext"><i></i><span>Extensions</span></div><div class="tile auto"><i></i><span>Automation</span></div></div></div></section>
  <section class="section"><div class="shell"><SectionHeading eyebrow="Selected work" title="Focused products, built with purpose." text="A growing collection of mobile, browser, and automation projects shaped around real everyday problems."/><div class="projects">{projects.filter(p=>p.featured).map(project=><ProjectCard project={project}/>)}<ProjectCard project={projects[3]}/></div></div></section>
  <section class="section philosophy"><div class="shell"><SectionHeading eyebrow="Building philosophy" title="Simple software takes thoughtful work."/><div class="principles"><article data-reveal><span>01</span><h3>Useful first</h3><p>Start with a real problem and remove everything that does not help solve it.</p></article><article data-reveal><span>02</span><h3>Simple by design</h3><p>Powerful software should still feel understandable and easy to use.</p></article><article data-reveal><span>03</span><h3>Built with care</h3><p>Performance, privacy, reliability, and visual polish are part of the product—not afterthoughts.</p></article></div></div></section>
  <section class="section"><div class="shell focus" data-reveal><div><p class="eyebrow">Current focus</p><h2>Preparing the next releases.</h2></div><p>Currently preparing Swoopix and several browser tools for their first public releases.</p></div></section>
  <section class="section"><div class="shell cta" data-reveal><p class="eyebrow">Start a conversation</p><h2>Have a useful problem worth solving?</h2><p>I’m always interested in thoughtful products, technical collaborations, and opportunities to build something meaningful.</p><ButtonLink href="/contact">Get in touch</ButtonLink></div></section>
</BaseLayout>
<style>.hero{min-height:calc(100vh - 4.6rem);display:grid;align-items:center;padding:5rem 0}.hero-grid{display:grid;grid-template-columns:minmax(0,1.12fr) minmax(22rem,.88fr);gap:clamp(2rem,7vw,7rem);align-items:center}.hero h1{font-size:clamp(3.1rem,7.3vw,6.6rem);max-width:12ch;margin:.8rem 0 1.5rem}.lead{font-size:clamp(1.05rem,2vw,1.25rem);color:var(--text-secondary);line-height:1.7;max-width:40rem}.buttons{display:flex;gap:.75rem;margin-top:2rem;flex-wrap:wrap}.hero-visual{aspect-ratio:1;position:relative;display:grid;place-items:center}.hero-visual:before{content:'';position:absolute;inset:8%;background:radial-gradient(circle,var(--accent) 0,transparent 64%);opacity:.15}.orbit{position:absolute;border:1px solid var(--border);border-radius:50%}.orbit.one{inset:16%}.orbit.two{inset:2%;border-style:dashed}.wk{width:7.5rem;height:7.5rem;display:grid;place-items:center;border-radius:2rem;background:var(--text-primary);color:var(--background);font-size:2.6rem;font-weight:800;letter-spacing:-.08em;box-shadow:0 30px 70px #0007;z-index:2}.tile{position:absolute;display:flex;align-items:center;gap:.6rem;padding:.65rem .85rem;border:1px solid var(--border);background:color-mix(in srgb,var(--surface) 88%,transparent);backdrop-filter:blur(12px);border-radius:.7rem;color:var(--text-secondary);font-size:.8rem}.tile i{width:.55rem;height:.55rem;background:var(--accent-bright);border-radius:50%}.ios{left:0;top:28%}.ext{right:0;top:20%}.auto{right:4%;bottom:17%}.section{padding:6rem 0}.projects{display:grid;gap:1.25rem}.projects>article:last-child{grid-template-columns:1fr 1fr}.philosophy{background:var(--surface)}.principles{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:1rem;overflow:hidden}.principles article{padding:2rem;background:var(--surface)}.principles span{font-family:monospace;color:var(--accent-bright)}.principles h3{margin-top:3rem}.principles p{color:var(--text-secondary)}.focus{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;border-block:1px solid var(--border);padding-block:3.5rem}.focus h2{margin:0}.focus>p{color:var(--text-secondary);font-size:1.15rem}.cta{text-align:center;padding:clamp(3rem,8vw,6rem);border:1px solid var(--border);border-radius:1.2rem;background:radial-gradient(circle at 50% 110%,color-mix(in srgb,var(--accent) 24%,transparent),transparent 48%),var(--surface)}.cta h2{max-width:15ch;margin:.5rem auto 1rem}.cta>p:not(.eyebrow){color:var(--text-secondary);max-width:42rem;margin:0 auto 2rem}@media(max-width:800px){.hero{min-height:auto}.hero-grid{grid-template-columns:1fr}.hero-visual{width:min(90%,28rem);margin:auto;order:-1}.principles{grid-template-columns:1fr}.principles h3{margin-top:1.5rem}.focus{grid-template-columns:1fr;gap:1rem}}@media(max-width:520px){.hero{padding:2.5rem 0 4rem}.hero h1{font-size:2.8rem}.hero-visual{width:100%}.tile{font-size:.7rem}.section{padding:4rem 0}}</style>
