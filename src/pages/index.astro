---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectRow from '../components/ProjectRow.astro';
import { projects } from '../data/projects';
import { journey, skillGroups } from '../data/journey';

// Everything except the "More in progress" placeholder card, which was filler.
const shown = projects.filter((project) => project.slug !== 'more');
---

<BaseLayout>
  <!-- ===================================================================
       Hero — states plainly who he is and what he's doing right now.
       =================================================================== -->
  <section class="hero" data-scroll-fade>
    <div class="shell">
      <h1 class="hero-title" data-lines>
        <span class="line"><span>Ward Khleif</span></span>
      </h1>

      <p class="hero-sub" data-lines>
        <span class="line"><span>Computer science student.</span></span>
        <span class="line"><span>I build iOS apps and browser tools.</span></span>
      </p>

      <p class="hero-body lede" data-reveal data-reveal-delay="420">
        Most of what I know came from building things that didn't work at first.
        Below is what I've made, and how I got here.
      </p>

      <nav class="hero-links" aria-label="Page sections" data-stagger style="--stagger-step:90ms">
        <a href="#work">Work</a>
        <a href="#journey">Journey</a>
        <a href="#skills">Skills</a>
      </nav>
    </div>
  </section>

  <!-- ===================================================================
       Work — the reason the page exists.
       =================================================================== -->
  <section class="section work" id="work">
    <div class="shell">
      <header class="section-head" data-lines>
        <span class="eyebrow line"><span>Work</span></span>
        <h2 class="line"><span>Things I've built</span></h2>
      </header>
      <div class="draw-rule"></div>

      <div class="rows">
        {shown.map((project, index) => <ProjectRow project={project} index={index} />)}
      </div>
    </div>
  </section>

  <!-- ===================================================================
       Journey — pinned chapters, one milestone at a time.
       =================================================================== -->
  <section class="journey" id="journey" data-journey-scene style={`--journey-count:${journey.length}`}>
    <div class="journey-sticky shell">
      <header class="journey-heading">
        <span class="eyebrow">Journey</span>
        <h2>How I got here</h2>
        <p>Not a résumé. Just the moments that changed what I knew how to build.</p>
      </header>

      <div class="journey-stage">
        <div class="journey-atmosphere" aria-hidden="true">
          <span class="journey-ghost">{journey[0]?.year}</span>
          <i></i><i></i><i></i>
        </div>
        <ol class="timeline">
          {journey.map((entry, index) => (
            <li class:list={['entry', { current: entry.current }]} data-journey-card={index}>
              <div class="entry-top"><span>{String(index + 1).padStart(2, '0')} / {String(journey.length).padStart(2, '0')}</span><p class="year">{entry.year}</p></div>
              <div class="entry-body"><h3>{entry.title}</h3><p>{entry.body}</p></div>
              {entry.current && <span class="live"><i></i> Right now</span>}
            </li>
          ))}
        </ol>
      </div>

      <div class="journey-footer" aria-hidden="true">
        <span class="journey-status">CHAPTER 01</span>
        <div class="journey-progress"><span></span></div>
        <span>SCROLL TO CONTINUE ↓</span>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       Skills — grouped by where they're used. No proficiency theatre.
       =================================================================== -->
  <section class="section skills" id="skills">
    <div class="shell">
      <header class="section-head" data-lines>
        <span class="eyebrow line"><span>Skills</span></span>
        <h2 class="line"><span>What I work with</span></h2>
      </header>

      <div class="skill-grid" data-stagger style="--stagger-step:100ms">
        {skillGroups.map((group) => (
          <div class="skill-group">
            <h3>{group.label}</h3>
            <ul data-stagger style="--stagger-step:55ms">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================================
       Closing — an open door, not a pitch.
       =================================================================== -->
  <section class="section closing">
    <div class="shell">
      <p class="closing-line" data-lines>
        <span class="line"><span>Still building. Still learning.</span></span>
      </p>
      <p class="closing-note" data-reveal>
        If something here is worth talking about, <a href="/contact">the contact page</a> is right there.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---------------------------------------------------------- */
  /* Sized by its own content, not by the viewport. A forced full-height hero
     just manufactures empty space on tall screens. */
  .hero {
    padding-block: clamp(4.5rem, 12vh, 8rem) clamp(4.5rem, 11vh, 7rem);
  }

  /* Lifts and dissolves on the way out instead of just scrolling away. */
  :global(.has-motion) .hero {
    opacity: var(--fade-opacity, 1);
    transform: translate3d(0, var(--fade-y, 0), 0);
    will-change: opacity, transform;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    letter-spacing: -0.048em;
  }

  .hero-sub {
    margin: clamp(1.25rem, 3vw, 2rem) 0 0;
    font-size: clamp(1.5rem, 3.4vw, 2.6rem);
    font-weight: 500;
    line-height: 1.16;
    letter-spacing: -0.032em;
    color: var(--text-secondary);
  }

  /* The second line lands in full ink — that's the sentence that matters. */
  .hero-sub .line:last-child > span {
    color: var(--text-primary);
  }

  .hero-body {
    max-width: 34rem;
    margin: clamp(2rem, 4vw, 2.75rem) 0 0;
  }

  .hero-links {
    display: flex;
    gap: 2rem;
    margin-top: 2.5rem;
  }

  .hero-links a {
    position: relative;
    padding-bottom: 0.3rem;
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
  }

  .hero-links a::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 0.4s var(--ease-out);
  }

  .hero-links a:hover::after {
    transform: scaleX(1);
  }

  /* ---- Section headings ---------------------------------------------- */
  .section-head {
    margin-bottom: 1.75rem;
  }

  .section-head .eyebrow {
    margin-bottom: 0.9rem;
  }

  .section-head h2 {
    margin: 0;
  }

  .journey .section-head,
  .skills .section-head {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .work {
    padding-top: 0;
  }

  .work .draw-rule {
    margin-bottom: clamp(1rem, 3vw, 2rem);
  }

  .rows {
    border-bottom: 1px solid var(--border);
  }

  /* ---- Journey -------------------------------------------------------- */
  .journey{height:calc(var(--journey-count) * 92vh + 100vh);position:relative;background:var(--text-primary);color:var(--background);border-block:1px solid var(--border);isolation:isolate}
  .journey-sticky{height:100vh;position:sticky;top:0;display:grid;grid-template-columns:.72fr 1.28fr;grid-template-rows:1fr auto;gap:clamp(2rem,7vw,7rem);align-items:center;overflow:hidden;padding-block:clamp(4.5rem,9vh,7rem) 2rem}
  .journey-heading{position:relative;z-index:4;align-self:center}.journey-heading .eyebrow{color:var(--accent-bright)}.journey-heading h2{max-width:7ch;margin:.8rem 0 1.4rem;font-size:clamp(3.5rem,7vw,6.8rem);line-height:.84;letter-spacing:-.065em}.journey-heading>p{max-width:25rem;margin:0;color:color-mix(in srgb,var(--background) 62%,transparent);line-height:1.65}
  .journey-stage{position:relative;z-index:2;align-self:stretch;display:grid;place-items:center;perspective:1400px}.timeline{position:relative;z-index:3;width:min(100%,40rem);height:28rem;margin:0;padding:0;list-style:none;transform-style:preserve-3d}
  .entry{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:space-between;padding:clamp(1.6rem,4vw,3rem);border:1px solid color-mix(in srgb,var(--background) 24%,transparent);border-radius:1.1rem;background:color-mix(in srgb,var(--text-primary) 86%,var(--surface));box-shadow:0 40px 100px rgba(0,0,0,.36);opacity:var(--chapter-opacity,0);transform:translate3d(var(--chapter-x,80px),var(--chapter-y,40px),var(--chapter-z,-180px)) rotateY(var(--chapter-rotate,8deg)) scale(var(--chapter-scale,.84));filter:blur(var(--chapter-blur,9px));will-change:transform,opacity,filter;pointer-events:none}.entry.is-active{pointer-events:auto}.entry::before{content:"";position:absolute;inset:-1px;border-radius:inherit;background:radial-gradient(circle at var(--chapter-glow-x,85%) 15%,color-mix(in srgb,var(--accent-bright) 14%,transparent),transparent 38%);pointer-events:none}.entry-top{display:flex;justify-content:space-between;gap:2rem;padding-bottom:1.2rem;border-bottom:1px solid color-mix(in srgb,var(--background) 18%,transparent);font:500 .66rem/1 monospace;letter-spacing:.09em;text-transform:uppercase}.entry-top>span{color:var(--accent-bright)}.year{margin:0;color:var(--background);font-variant-numeric:tabular-nums}.entry-body{position:relative;z-index:1}.entry-body h3{max-width:14ch;margin:0 0 1rem;font-size:clamp(2rem,4vw,3.7rem);line-height:.94;letter-spacing:-.055em}.entry-body p{max-width:34rem;margin:0;color:color-mix(in srgb,var(--background) 62%,transparent);line-height:1.7}.live{display:inline-flex;align-items:center;gap:.6rem;width:max-content;color:var(--accent-bright);font-size:.7rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase}.live i{width:.5rem;height:.5rem;border-radius:50%;background:currentColor;box-shadow:0 0 0 5px color-mix(in srgb,var(--accent-bright) 12%,transparent);animation:pulse 2.4s ease-out infinite}
  .journey-atmosphere{position:absolute;inset:0;display:grid;place-items:center;pointer-events:none}.journey-ghost{position:absolute;color:var(--accent-bright);font-size:clamp(8rem,18vw,18rem);font-weight:650;line-height:.8;letter-spacing:-.09em;opacity:.09;transform:translate3d(var(--ghost-x,0),var(--ghost-y,0),0) scale(var(--ghost-scale,1));filter:blur(var(--ghost-blur,0));white-space:nowrap}.journey-atmosphere i{position:absolute;width:min(55vw,38rem);aspect-ratio:1;border:1px solid color-mix(in srgb,var(--background) 10%,transparent);border-radius:50%;transform:rotate(calc(var(--journey-progress,0) * 180deg))}.journey-atmosphere i:nth-of-type(2){width:min(40vw,27rem);border-style:dashed;transform:rotate(calc(var(--journey-progress,0) * -260deg))}.journey-atmosphere i:nth-of-type(3){width:.6rem;background:var(--accent-bright);border:0;box-shadow:0 0 20px var(--accent-bright);transform:rotate(var(--journey-angle,0deg)) translateX(15rem)}
  .journey-footer{grid-column:1/-1;display:grid;grid-template-columns:auto 1fr auto;gap:1.2rem;align-items:center;color:color-mix(in srgb,var(--background) 54%,transparent);font:500 .58rem/1 monospace;letter-spacing:.1em}.journey-status{color:var(--background)}.journey-progress{height:2px;background:color-mix(in srgb,var(--background) 13%,transparent);overflow:hidden}.journey-progress span{display:block;width:100%;height:100%;background:var(--accent-bright);transform:scaleX(var(--journey-progress,0));transform-origin:left}
  @keyframes pulse{0%{transform:scale(.8);opacity:.8}70%,100%{transform:scale(2.6);opacity:0}}

  @media(max-width:760px){.journey{height:auto;padding-block:5rem}.journey-sticky{height:auto;position:relative;display:block;overflow:visible;padding-block:0}.journey-heading{margin-bottom:3rem}.journey-heading h2{font-size:3.6rem}.journey-stage{display:block}.journey-atmosphere,.journey-footer{display:none}.timeline{width:100%;height:auto;display:grid;gap:1rem}.entry{position:relative;inset:auto;min-height:24rem;opacity:1;transform:none;filter:none}.entry-body h3{font-size:2.2rem}}
  @media(prefers-reduced-motion:reduce){.journey{height:auto;padding-block:6rem}.journey-sticky{height:auto;position:relative;display:block;overflow:visible;padding-block:0}.journey-heading{margin-bottom:3rem}.journey-stage{display:block}.journey-atmosphere,.journey-footer{display:none}.timeline{height:auto;display:grid;gap:1rem}.entry{position:relative;opacity:1;transform:none;filter:none}.live i{animation:none}}

  /* ---- Skills --------------------------------------------------------- */
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: clamp(2rem, 4vw, 3rem);
  }

  .skill-group h3 {
    margin: 0 0 1.1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .skill-group ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.6rem;
  }

  .skill-group li {
    font-size: 0.98rem;
  }

  /* ---- Closing -------------------------------------------------------- */
  .closing {
    border-top: 1px solid var(--border);
  }

  .closing-line {
    margin: 0;
    font-size: clamp(1.9rem, 4.5vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.038em;
    line-height: 1.08;
  }

  .closing-note {
    margin: 1.5rem 0 0;
    color: var(--text-secondary);
  }

  .closing-note a {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--border-strong);
  }

  .closing-note a:hover {
    text-decoration-color: currentColor;
  }

  @media (max-width: 900px) {
    .entry {
      grid-template-columns: 7rem minmax(0, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 700px) {
    /* Year stacks above the entry — a 7rem column starves the text on phones. */
    .entry {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      padding-left: 1.75rem;
    }

    .year {
      font-size: 0.82rem;
    }

    .hero-links {
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .skill-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem 1.5rem;
    }
  }

  @media (max-width: 420px) {
    .skill-grid {
      grid-template-columns: 1fr;
    }

    .hero-links {
      gap: 1.25rem;
    }

    .closing-line {
      font-size: 1.75rem;
    }
  }
</style>
