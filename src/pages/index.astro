---
import BaseLayout from '../layouts/BaseLayout.astro'; import ButtonLink from '../components/ButtonLink.astro'; import SectionHeading from '../components/SectionHeading.astro'; import ProjectCard from '../components/ProjectCard.astro'; import { projects } from '../data/projects';
import '../styles/home-motion.css';
const headline = ['I build useful apps,', 'browser extensions,', 'and automation tools.'];
---
<BaseLayout>
  <section class="hero"><div class="hero-noise" aria-hidden="true"></div><div class="shell hero-grid"><div class="hero-copy"><p class="eyebrow hero-enter delay-1">Independent Software Developer</p><h1 aria-label="I build useful apps, browser extensions, and automation tools.">{headline.map((line,i)=><span class={`headline-mask delay-${i+2}`}><span>{line}{i < headline.length - 1 ? ' ' : ''}</span></span>)}</h1><p class="lead hero-enter delay-5">I’m Ward Khleif. I design and develop focused digital products that solve real problems without unnecessary complexity.</p><div class="buttons hero-enter delay-6"><ButtonLink href="/projects">Explore my work</ButtonLink><ButtonLink href="/about" variant="secondary">About me</ButtonLink></div></div><div class="hero-visual hero-enter delay-3" aria-hidden="true" data-parallax><div class="orbital-glow"></div><div class="orbit one"><i></i></div><div class="orbit two"><i></i></div><div class="orbit three"></div><div class="wk"><span>WK</span></div><div class="tile ios"><i></i><span>iOS apps</span></div><div class="tile ext"><i></i><span>Extensions</span></div><div class="tile auto"><i></i><span>Automation</span></div></div></div><div class="scroll-cue hero-enter delay-6" aria-hidden="true"><span>Scroll to explore</span><i></i></div></section>
  <div class="capability-rail" aria-hidden="true"><div><span>iOS DEVELOPMENT</span><i>✦</i><span>BROWSER EXTENSIONS</span><i>✦</i><span>AUTOMATION SYSTEMS</span><i>✦</i><span>DIGITAL PRODUCTS</span><i>✦</i><span>iOS DEVELOPMENT</span><i>✦</i><span>BROWSER EXTENSIONS</span><i>✦</i><span>AUTOMATION SYSTEMS</span><i>✦</i><span>DIGITAL PRODUCTS</span><i>✦</i></div></div>
  <section class="section"><div class="shell"><SectionHeading eyebrow="Selected work" title="Focused products, built with purpose." text="A growing collection of mobile, browser, and automation projects shaped around real everyday problems."/><div class="projects">{projects.filter(p=>p.featured).map(project=><ProjectCard project={project}/>)}<ProjectCard project={projects[3]}/></div></div></section>
  <section class="story" data-scroll-scene>
    <div class="story-sticky shell">
      <div class="story-copy">
        <p class="eyebrow">From friction to flow</p>
        <h2>Good products make the hard part disappear.</h2>
        <p class="story-intro">Every project moves through the same deliberate arc: find the friction, shape a focused core, then refine until the experience feels obvious.</p>
        <div class="story-steps">
          <article data-story-step="0"><span>01</span><div><h3>Notice the friction</h3><p>Start with a real moment that feels slower, harder, or more confusing than it should.</p></div></article>
          <article data-story-step="1"><span>02</span><div><h3>Shape the core</h3><p>Remove everything that does not serve the central job and build the reliable path first.</p></div></article>
          <article data-story-step="2"><span>03</span><div><h3>Refine the feeling</h3><p>Polish the details until performance, privacy, and interaction work as one quiet system.</p></div></article>
        </div>
      </div>
      <div class="story-stage" aria-hidden="true">
        <div class="stage-rings"><i></i><i></i><i></i></div>
        <div class="stage-card card-one"><small>01 / PROBLEM</small><strong>Real friction</strong><span>Observe what gets in the way.</span></div>
        <div class="stage-card card-two"><small>02 / CORE</small><strong>Clear logic</strong><span>Build the simplest useful path.</span></div>
        <div class="stage-card card-three"><small>03 / EXPERIENCE</small><strong>Quiet polish</strong><span>Make complexity feel effortless.</span></div>
        <div class="stage-core">WK<span>PRODUCT<br/>THINKING</span></div>
      </div>
    </div>
  </section>
  <section class="section philosophy" data-philosophy-scene><div class="shell philosophy-sticky"><div class="philosophy-heading"><SectionHeading eyebrow="Building philosophy" title="Simple software takes thoughtful work."/><p class="philosophy-progress" aria-hidden="true"><span></span></p></div><div class="principles"><article data-philosophy-card="0"><span>01</span><h3>Useful first</h3><p>Start with a real problem and remove everything that does not help solve it.</p><small>PROBLEM → PURPOSE</small></article><article data-philosophy-card="1"><span>02</span><h3>Simple by design</h3><p>Powerful software should still feel understandable and easy to use.</p><small>COMPLEXITY → CLARITY</small></article><article data-philosophy-card="2"><span>03</span><h3>Built with care</h3><p>Performance, privacy, reliability, and visual polish are part of the product—not afterthoughts.</p><small>FUNCTION → FEELING</small></article></div></div></section>
  <section class="section"><div class="shell focus" data-reveal><div><p class="eyebrow">Current focus</p><h2>Preparing the next releases.</h2></div><p>Currently preparing Swoopix and several browser tools for their first public releases.</p></div></section>
  <section class="section"><div class="shell cta" data-reveal><p class="eyebrow">Start a conversation</p><h2>Have a useful problem worth solving?</h2><p>I’m always interested in thoughtful products, technical collaborations, and opportunities to build something meaningful.</p><ButtonLink href="/contact">Get in touch</ButtonLink></div></section>
</BaseLayout>
<style>.hero{min-height:calc(100svh - 4.6rem);display:grid;align-items:center;padding:5rem 0;position:relative;overflow:hidden;transform-origin:center top}.hero-noise{position:absolute;inset:0;opacity:.04;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.7'/%3E%3C/svg%3E");mix-blend-mode:soft-light}.hero-grid{display:grid;grid-template-columns:minmax(0,1.12fr) minmax(22rem,.88fr);gap:clamp(2rem,7vw,7rem);align-items:center;position:relative;transform:translateY(var(--hero-y,0)) scale(var(--hero-scale,1));opacity:var(--hero-opacity,1);filter:blur(var(--hero-blur,0));will-change:transform,opacity,filter}.hero h1{font-size:clamp(3.1rem,7.3vw,6.6rem);max-width:12ch;margin:.8rem 0 1.5rem}.headline-mask{display:block;overflow:hidden;padding-bottom:.06em;margin-bottom:-.06em}.headline-mask>span{display:block;animation:headline-rise 1s cubic-bezier(.16,1,.3,1) both;animation-delay:calc(.14s * var(--line-delay,1))}.headline-mask.delay-2>span{--line-delay:1}.headline-mask.delay-3>span{--line-delay:2}.headline-mask.delay-4>span{--line-delay:3}.hero-enter{animation:hero-fade .9s cubic-bezier(.22,1,.36,1) both}.delay-1{animation-delay:.05s}.delay-3{animation-delay:.28s}.delay-5{animation-delay:.48s}.delay-6{animation-delay:.62s}.lead{font-size:clamp(1.05rem,2vw,1.25rem);color:var(--text-secondary);line-height:1.7;max-width:40rem}.buttons{display:flex;gap:.75rem;margin-top:2rem;flex-wrap:wrap}.hero-visual{aspect-ratio:1;position:relative;display:grid;place-items:center;transform:translate3d(var(--parallax-x,0),var(--parallax-y,0),0);transition:transform .4s cubic-bezier(.2,.8,.2,1)}.orbital-glow{position:absolute;inset:13%;border-radius:50%;background:var(--accent);filter:blur(90px);opacity:.14;animation:glow-breathe 5s ease-in-out infinite}.orbit{position:absolute;border:1px solid var(--border);border-radius:50%}.orbit.one{inset:16%;animation:orbit-spin 20s linear infinite}.orbit.two{inset:2%;border-style:dashed;animation:orbit-spin 34s linear infinite reverse}.orbit.three{inset:29%;opacity:.55;animation:orbit-spin 14s linear infinite}.orbit>i{position:absolute;width:.55rem;height:.55rem;border-radius:50%;background:var(--accent-bright);box-shadow:0 0 16px var(--accent-bright);top:12%;left:14%}.orbit.two>i{top:auto;left:auto;right:17%;bottom:8%;width:.35rem;height:.35rem}.wk{width:7.5rem;height:7.5rem;display:grid;place-items:center;border-radius:2rem;background:var(--text-primary);color:var(--background);font-size:2.6rem;font-weight:800;letter-spacing:-.08em;box-shadow:0 30px 70px #0007;z-index:2;animation:monogram-float 5s ease-in-out infinite;position:relative;overflow:hidden}.wk:after{content:"";position:absolute;inset:-80%;background:linear-gradient(110deg,transparent 40%,rgba(255,255,255,.35),transparent 60%);animation:sheen 6s ease-in-out infinite}.wk span{position:relative;z-index:1}.tile{position:absolute;display:flex;align-items:center;gap:.6rem;padding:.65rem .85rem;border:1px solid var(--border);background:color-mix(in srgb,var(--surface) 80%,transparent);backdrop-filter:blur(16px);border-radius:.7rem;color:var(--text-secondary);font-size:.8rem;box-shadow:0 12px 35px rgba(0,0,0,.12);animation:tile-float 4s ease-in-out infinite}.tile i{width:.55rem;height:.55rem;background:var(--accent-bright);border-radius:50%;box-shadow:0 0 10px var(--accent-bright)}.ios{left:0;top:28%}.ext{right:0;top:20%;animation-delay:-1.3s}.auto{right:4%;bottom:17%;animation-delay:-2.6s}.scroll-cue{position:absolute;bottom:1.2rem;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:.75rem;color:var(--text-secondary);font-size:.68rem;text-transform:uppercase;letter-spacing:.14em;opacity:calc(1 - var(--hero-progress,0))}.scroll-cue i{display:block;width:2.2rem;height:1px;background:var(--border);position:relative;overflow:hidden}.scroll-cue i:after{content:"";position:absolute;inset:0;background:var(--accent-bright);transform:translateX(-100%);animation:scroll-line 2s ease-in-out infinite}.capability-rail{overflow:hidden;border-block:1px solid var(--border);padding:.85rem 0;color:var(--text-secondary);font:600 .7rem/1 monospace;letter-spacing:.15em;white-space:nowrap}.capability-rail>div{display:inline-flex;align-items:center;gap:2rem;min-width:max-content;animation:rail 28s linear infinite}.capability-rail i{color:var(--accent-bright);font-style:normal}.section{padding:6rem 0}.projects{display:grid;gap:1.25rem}.projects>article:last-child{grid-template-columns:1fr 1fr}.story{height:260vh;position:relative;background:var(--background);border-block:1px solid var(--border)}.story-sticky{height:100vh;position:sticky;top:0;display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(3rem,8vw,8rem);align-items:center;overflow:hidden}.story-copy h2{max-width:11ch}.story-intro{max-width:34rem;color:var(--text-secondary);font-size:1.05rem;line-height:1.7}.story-steps{margin-top:2rem}.story-steps article{display:grid;grid-template-columns:2.5rem 1fr;gap:1rem;padding:1rem 0;border-top:1px solid var(--border);opacity:var(--step-opacity,.28);transform:translateX(var(--step-x,0));transition:opacity .25s,color .25s}.story-steps article:last-child{border-bottom:1px solid var(--border)}.story-steps article>span{color:var(--accent-bright);font:.75rem monospace}.story-steps h3{font-size:1.05rem;margin:0 0 .25rem}.story-steps p{color:var(--text-secondary);font-size:.86rem;margin:0}.story-stage{aspect-ratio:1;position:relative;display:grid;place-items:center;transform:scale(var(--scene-scale,.86)) rotate(var(--scene-rotate,-8deg));opacity:var(--scene-opacity,.5);will-change:transform,opacity}.stage-rings{position:absolute;inset:4%;display:grid;place-items:center}.stage-rings:before,.stage-rings:after,.stage-rings i{content:"";position:absolute;border:1px solid var(--border);border-radius:50%}.stage-rings:before{inset:0}.stage-rings:after{inset:16%;border-style:dashed}.stage-rings i:nth-child(1){inset:31%;background:color-mix(in srgb,var(--accent) 4%,transparent)}.stage-rings i:nth-child(2){inset:8%;border-color:color-mix(in srgb,var(--accent-bright) 22%,var(--border));transform:rotate(calc(var(--scene-progress,0) * 180deg))}.stage-rings i:nth-child(3){inset:23%;transform:rotate(calc(var(--scene-progress,0) * -240deg))}.stage-core{width:8.5rem;height:8.5rem;border-radius:2rem;background:var(--text-primary);color:var(--background);display:grid;place-items:center;font-size:2rem;font-weight:800;letter-spacing:-.08em;box-shadow:0 35px 90px rgba(0,0,0,.32);z-index:3}.stage-core span{font:600 .48rem/1.3 monospace;letter-spacing:.08em;position:absolute;margin-top:4.6rem;opacity:.6}.stage-card{position:absolute;width:10.5rem;padding:1rem;border:1px solid var(--border);border-radius:.9rem;background:color-mix(in srgb,var(--surface) 88%,transparent);backdrop-filter:blur(18px);box-shadow:0 20px 60px rgba(0,0,0,.18);display:grid;gap:.25rem;transform:translate3d(var(--card-x,0),var(--card-y,0),0) rotate(var(--card-r,0deg));opacity:var(--card-opacity,0)}.stage-card small{font:.55rem monospace;color:var(--accent-bright)}.stage-card strong{font-size:.9rem}.stage-card span{color:var(--text-secondary);font-size:.65rem}.card-one{left:2%;top:17%}.card-two{right:0;top:31%}.card-three{left:16%;bottom:5%}.philosophy{background:var(--surface);position:relative;overflow:hidden}.philosophy:after{content:"";position:absolute;width:28rem;height:28rem;border-radius:50%;right:-12rem;bottom:-20rem;background:var(--accent);filter:blur(120px);opacity:.08}.principles{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:1rem;overflow:hidden}.principles article{padding:2rem;background:var(--surface);transition:background .3s,transform .3s}.principles article:hover{background:var(--surface-elevated);transform:translateY(-5px)}.principles span{font-family:monospace;color:var(--accent-bright)}.principles h3{margin-top:3rem}.principles p{color:var(--text-secondary)}.focus{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;border-block:1px solid var(--border);padding-block:3.5rem}.focus h2{margin:0}.focus>p{color:var(--text-secondary);font-size:1.15rem}.cta{text-align:center;padding:clamp(3rem,8vw,6rem);border:1px solid var(--border);border-radius:1.2rem;background:radial-gradient(circle at 50% 110%,color-mix(in srgb,var(--accent) 24%,transparent),transparent 48%),var(--surface);position:relative;overflow:hidden}.cta:before{content:"";position:absolute;inset:-1px;background:conic-gradient(from var(--angle,0deg),transparent 60%,color-mix(in srgb,var(--accent-bright) 50%,transparent),transparent 72%);animation:border-spin 7s linear infinite;z-index:0}.cta:after{content:"";position:absolute;inset:1px;border-radius:calc(1.2rem - 1px);background:radial-gradient(circle at 50% 110%,color-mix(in srgb,var(--accent) 24%,transparent),transparent 48%),var(--surface)}.cta>*{position:relative;z-index:1}.cta h2{max-width:15ch;margin:.5rem auto 1rem}.cta>p:not(.eyebrow){color:var(--text-secondary);max-width:42rem;margin:0 auto 2rem}@property --angle{syntax:'<angle>';initial-value:0deg;inherits:false}@keyframes headline-rise{from{transform:translateY(115%);opacity:0}to{transform:none;opacity:1}}@keyframes hero-fade{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}@keyframes orbit-spin{to{transform:rotate(1turn)}}@keyframes glow-breathe{50%{opacity:.24;transform:scale(1.13)}}@keyframes monogram-float{50%{transform:translateY(-8px) rotate(1.5deg);box-shadow:0 42px 90px #0008}}@keyframes sheen{0%,55%{transform:translateX(-70%) rotate(12deg)}85%,100%{transform:translateX(70%) rotate(12deg)}}@keyframes tile-float{50%{transform:translateY(-8px)}}@keyframes scroll-line{50%,100%{transform:translateX(100%)}}@keyframes rail{to{transform:translateX(-50%)}}@keyframes border-spin{to{--angle:360deg}}@media(max-width:800px){.hero{min-height:auto}.hero-grid{grid-template-columns:1fr;transform:none!important;opacity:1!important;filter:none!important}.hero-visual{width:min(90%,28rem);margin:auto;order:-1}.scroll-cue{display:none}.story{height:auto;padding:6rem 0}.story-sticky{height:auto;position:relative;grid-template-columns:1fr;overflow:visible}.story-stage{width:min(100%,30rem);margin:auto;transform:none;opacity:1}.stage-card{opacity:1}.card-one{--card-x:0;--card-y:0;--card-r:-4deg}.card-two{--card-x:0;--card-y:0;--card-r:4deg}.card-three{--card-x:0;--card-y:0;--card-r:-2deg}.story-steps article{opacity:1;transform:none}.principles{grid-template-columns:1fr}.principles h3{margin-top:1.5rem}.focus{grid-template-columns:1fr;gap:1rem}}@media(max-width:520px){.hero{padding:2.5rem 0 4rem}.hero h1{font-size:2.8rem}.hero-visual{width:100%}.tile{font-size:.7rem}.story-stage{transform:scale(.9);margin-block:-1rem}.stage-card{width:8.4rem}.section{padding:4rem 0}}</style>
