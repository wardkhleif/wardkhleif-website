---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectRow from '../components/ProjectRow.astro';
import { projects } from '../data/projects';
import { journey, skillGroups } from '../data/journey';

// Everything except the "More in progress" placeholder card, which was filler.
const shown = projects.filter((project) => project.slug !== 'more');
---

<BaseLayout>
  <!-- ===================================================================
       Hero — states plainly who he is and what he's doing right now.
       =================================================================== -->
  <section class="hero" data-scroll-fade>
    <div class="shell">
      <h1 class="hero-title" data-lines>
        <span class="line"><span>Ward Khleif</span></span>
      </h1>

      <p class="hero-sub" data-lines>
        <span class="line"><span>Computer science student.</span></span>
        <span class="line"><span>I build iOS apps and browser tools.</span></span>
      </p>

      <p class="hero-body lede" data-reveal data-reveal-delay="420">
        Most of what I know came from building things that didn't work at first.
        Below is what I've made, and how I got here.
      </p>

      <nav class="hero-links" aria-label="Page sections" data-stagger style="--stagger-step:90ms">
        <a href="#work">Work</a>
        <a href="#journey">Journey</a>
        <a href="#skills">Skills</a>
      </nav>
    </div>
  </section>

  <!-- ===================================================================
       Work — the reason the page exists.
       =================================================================== -->
  <section class="section work" id="work">
    <div class="shell">
      <header class="section-head" data-lines>
        <span class="eyebrow line"><span>Work</span></span>
        <h2 class="line"><span>Things I've built</span></h2>
      </header>
      <div class="draw-rule"></div>

      <div class="rows">
        {shown.map((project, index) => <ProjectRow project={project} index={index} />)}
      </div>
    </div>
  </section>

  <!-- ===================================================================
       Journey — the spine draws itself as you scroll past it.
       =================================================================== -->
  <section class="section journey" id="journey">
    <div class="shell">
      <header class="section-head" data-lines>
        <span class="eyebrow line"><span>Journey</span></span>
        <h2 class="line"><span>How I got here</span></h2>
      </header>

      <ol class="timeline" data-timeline>
        {journey.map((entry) => (
          <li class:list={['entry', { current: entry.current }]} data-reveal>
            <div class="marker" aria-hidden="true"></div>
            <p class="year">{entry.year}</p>
            <div class="entry-body">
              <h3>{entry.title}</h3>
              <p>{entry.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===================================================================
       Skills — grouped by where they're used. No proficiency theatre.
       =================================================================== -->
  <section class="section skills" id="skills">
    <div class="shell">
      <header class="section-head" data-lines>
        <span class="eyebrow line"><span>Skills</span></span>
        <h2 class="line"><span>What I work with</span></h2>
      </header>

      <div class="skill-grid" data-stagger style="--stagger-step:100ms">
        {skillGroups.map((group) => (
          <div class="skill-group">
            <h3>{group.label}</h3>
            <ul data-stagger style="--stagger-step:55ms">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================================
       Closing — an open door, not a pitch.
       =================================================================== -->
  <section class="section closing">
    <div class="shell">
      <p class="closing-line" data-lines>
        <span class="line"><span>Still building. Still learning.</span></span>
      </p>
      <p class="closing-note" data-reveal>
        If something here is worth talking about, <a href="/contact">the contact page</a> is right there.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---------------------------------------------------------- */
  /* Sized by its own content, not by the viewport. A forced full-height hero
     just manufactures empty space on tall screens. */
  .hero {
    padding-block: clamp(4.5rem, 12vh, 8rem) clamp(4.5rem, 11vh, 7rem);
  }

  /* Lifts and dissolves on the way out instead of just scrolling away. */
  :global(.has-motion) .hero {
    opacity: var(--fade-opacity, 1);
    transform: translate3d(0, var(--fade-y, 0), 0);
    will-change: opacity, transform;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    letter-spacing: -0.048em;
  }

  .hero-sub {
    margin: clamp(1.25rem, 3vw, 2rem) 0 0;
    font-size: clamp(1.5rem, 3.4vw, 2.6rem);
    font-weight: 500;
    line-height: 1.16;
    letter-spacing: -0.032em;
    color: var(--text-secondary);
  }

  /* The second line lands in full ink — that's the sentence that matters. */
  .hero-sub .line:last-child > span {
    color: var(--text-primary);
  }

  .hero-body {
    max-width: 34rem;
    margin: clamp(2rem, 4vw, 2.75rem) 0 0;
  }

  .hero-links {
    display: flex;
    gap: 2rem;
    margin-top: 2.5rem;
  }

  .hero-links a {
    position: relative;
    padding-bottom: 0.3rem;
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
  }

  .hero-links a::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 0.4s var(--ease-out);
  }

  .hero-links a:hover::after {
    transform: scaleX(1);
  }

  /* ---- Section headings ---------------------------------------------- */
  .section-head {
    margin-bottom: 1.75rem;
  }

  .section-head .eyebrow {
    margin-bottom: 0.9rem;
  }

  .section-head h2 {
    margin: 0;
  }

  .journey .section-head,
  .skills .section-head {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .work {
    padding-top: 0;
  }

  .work .draw-rule {
    margin-bottom: clamp(1rem, 3vw, 2rem);
  }

  .rows {
    border-bottom: 1px solid var(--border);
  }

  /* ---- Journey -------------------------------------------------------- */
  .journey {
    background: var(--surface);
    border-block: 1px solid var(--border);
  }

  .timeline {
    position: relative;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* Track + spine. The spine scales vertically with scroll progress, so the
     line appears to draw itself alongside the entries. */
  .timeline::before,
  .timeline::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6rem;
    bottom: 0.6rem;
    width: 1px;
  }

  .timeline::before {
    background: var(--border);
  }

  .timeline::after {
    background: var(--text-primary);
    transform: scaleY(var(--timeline-progress, 0));
    transform-origin: 50% 0;
  }

  .entry {
    position: relative;
    display: grid;
    grid-template-columns: 9rem minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: 0 0 clamp(2.75rem, 5vw, 4rem) clamp(2rem, 4vw, 3.5rem);
  }

  .entry:last-child {
    padding-bottom: 0;
  }

  /* Entries arrive from the spine rather than straight up, so the eye reads
     the line as the thing carrying them. */
  :global(.has-motion) .entry[data-reveal] {
    transform: translate3d(-14px, 14px, 0);
  }

  :global(.has-motion) .entry[data-reveal].is-revealed {
    transform: none;
  }

  .marker {
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 9px;
    height: 9px;
    margin-left: -4px;
    border-radius: 50%;
    background: var(--background);
    box-shadow: inset 0 0 0 1px var(--border-strong);
    transition: transform 0.7s var(--ease-out) 0.15s, background-color 0.5s var(--ease-out);
  }

  :global(.has-motion) .entry[data-reveal] .marker {
    transform: scale(0);
  }

  :global(.has-motion) .entry[data-reveal].is-revealed .marker {
    transform: scale(1);
  }

  .entry.current .marker {
    background: var(--text-primary);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--text-primary) 12%, transparent);
  }

  /* The one live entry gets a slow pulse — the only looping animation on the
     page, and it's carrying meaning. */
  .entry.current .marker::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--text-primary);
    animation: pulse 2.8s var(--ease-out) infinite;
  }

  @keyframes pulse {
    0% { transform: scale(0.8); opacity: 0.7; }
    70%, 100% { transform: scale(2.4); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .entry.current .marker::after {
      display: none;
    }
  }

  .year {
    margin: 0;
    color: var(--text-tertiary);
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .entry.current .year {
    color: var(--text-primary);
    font-weight: 500;
  }

  .entry-body h3 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.15rem, 1.9vw, 1.45rem);
  }

  .entry-body p {
    margin: 0;
    max-width: 42rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ---- Skills --------------------------------------------------------- */
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: clamp(2rem, 4vw, 3rem);
  }

  .skill-group h3 {
    margin: 0 0 1.1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .skill-group ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.6rem;
  }

  .skill-group li {
    font-size: 0.98rem;
  }

  /* ---- Closing -------------------------------------------------------- */
  .closing {
    border-top: 1px solid var(--border);
  }

  .closing-line {
    margin: 0;
    font-size: clamp(1.9rem, 4.5vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.038em;
    line-height: 1.08;
  }

  .closing-note {
    margin: 1.5rem 0 0;
    color: var(--text-secondary);
  }

  .closing-note a {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--border-strong);
  }

  .closing-note a:hover {
    text-decoration-color: currentColor;
  }

  @media (max-width: 900px) {
    .entry {
      grid-template-columns: 7rem minmax(0, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 700px) {
    /* Year stacks above the entry — a 7rem column starves the text on phones. */
    .entry {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      padding-left: 1.75rem;
    }

    .year {
      font-size: 0.82rem;
    }

    .hero-links {
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .skill-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem 1.5rem;
    }
  }

  @media (max-width: 420px) {
    .skill-grid {
      grid-template-columns: 1fr;
    }

    .hero-links {
      gap: 1.25rem;
    }

    .closing-line {
      font-size: 1.75rem;
    }
  }
</style>
