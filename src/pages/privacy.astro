---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy — Ward Khleif"
  description="Privacy notice for wardkhleif.com, a website with no cookies, advertising trackers, analytics, or form submissions by default."
>
  <section class="legal">
    <div class="shell legal-grid">
      <aside data-lines>
        <span class="eyebrow line"><span>Privacy</span></span>
        <h1 class="line"><span>A simple website privacy notice.</span></h1>
        <p class="line"><span>Last updated: July 2026</span></p>
      </aside>

      <article data-reveal>
        <h2>What this website collects</h2>
        <p>
          This website initially uses no cookies, advertising trackers, or
          analytics. It does not include a contact form and does not collect
          form submissions.
        </p>

        <h2>Theme preference</h2>
        <p>
          If you manually choose light or dark mode, that preference is
          stored locally in your browser. It is not sent to Ward or a third
          party.
        </p>

        <h2>Third-party services</h2>
        <p>
          The website may link to external services when public contact or
          project links are configured. Those services have their own
          privacy practices.
        </p>

        <h2>Product privacy</h2>
        <p>
          Individual products may have separate, product-specific privacy
          policies before release. Those policies will describe their
          permissions and data handling in context.
        </p>
        <ul class="product-policies">
          <li>
            <a href="/mailkey/privacy">MailKey</a> — the Chrome extension that
            fills email verification codes.
          </li>
        </ul>

        <h2>Changes</h2>
        <p>
          This notice may be revised as the website or its features change.
          The date above will be updated when material revisions are made.
        </p>

        <p class="note">This notice is provided for clarity and is not legal advice.</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    padding: clamp(4.5rem, 10vh, 7rem) 0;
  }

  .legal-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(3rem, 9vw, 9rem);
  }

  aside {
    position: sticky;
    top: 7rem;
    align-self: start;
  }

  aside h1 {
    margin: 0.8rem 0 1rem;
    font-size: clamp(2.7rem, 6vw, 5rem);
  }

  aside p {
    margin: 0;
    color: var(--text-secondary);
  }

  article {
    max-width: 45rem;
  }

  article h2 {
    font-size: 1.6rem;
    margin-top: 2.7rem;
  }

  article h2:first-child {
    margin-top: 0;
  }

  article p {
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .product-policies {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .product-policies a {
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--border-strong);
  }

  .product-policies a:hover {
    border-color: var(--accent-bright);
  }

  .note {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    margin-top: 3rem;
  }

  @media (max-width: 700px) {
    .legal-grid {
      grid-template-columns: 1fr;
    }

    aside {
      position: static;
    }
  }
</style>
