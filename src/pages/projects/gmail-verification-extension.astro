---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProject } from '../../data/projects';

const project = getProject('gmail-verification-extension');

const steps = [
  {
    title: 'The code arrives',
    text: 'You ask a site to email you a verification code. It lands in Gmail like it always does — MailKey changes nothing about that.',
  },
  {
    title: 'MailKey spots it',
    text: 'Because a code field is on screen, the extension asks Gmail for mail from the last 60 minutes only, reads it in memory, and pulls out the code.',
  },
  {
    title: 'You click Fill',
    text: 'The code appears in a chip beside the field, with the domain it came from. One click puts it in the box. It is never typed for you, and never submitted for you.',
  },
];

const guarantees = [
  {
    term: 'Read-only',
    detail:
      'Access is granted through Chrome itself (chrome.identity), scoped to gmail.readonly. There is no password field, no client secret, and no login form inside the extension.',
  },
  {
    term: 'The last hour, self-enforced',
    detail:
      'Google does not offer a time-limited Gmail permission, so the grant technically covers the whole mailbox. Every request MailKey makes carries an after: filter set to one hour ago — the limit is the extension’s own, kept in one small function, and it is stated plainly rather than implied.',
  },
  {
    term: 'Sixty seconds',
    detail:
      'A found code lives in session memory only, wiped when you use it, when the tab closes, or within a minute. Message bodies are parsed in memory and discarded — never written to disk.',
  },
  {
    term: 'No servers, no analytics',
    detail:
      'There is no backend. Requests go straight from your browser to Google. Nothing phones home, nothing is sold or shared, and there is no mechanism by which anyone else could read your mail.',
  },
  {
    term: 'Never automatic',
    detail:
      'MailKey does not fill without a click and never submits a form for you. The last decision is always yours.',
  },
];
---

<BaseLayout
  title="MailKey — Ward Khleif"
  description={project.shortDescription}
  breadcrumbs={[
    { name: 'Projects', href: '/projects' },
    { name: 'MailKey', href: project.detailUrl },
  ]}
>
  <article class="mailkey">
    <!-- Hero ------------------------------------------------------------- -->
    <section class="section hero">
      <div class="shell">
        <a class="back" href="/projects"><span aria-hidden="true">←</span> Projects</a>

        <div class="hero-grid">
          <div class="hero-copy">
            <div class="brand" data-reveal>
              <svg class="mark" viewBox="0 0 128 128" role="img" aria-label="MailKey logo: a keyhole set into an envelope">
                <rect width="128" height="128" rx="28" fill="#2563EB"></rect>
                <rect x="20" y="34" width="88" height="64" rx="10" fill="#FFFFFF"></rect>
                <path
                  d="M25 39 L64 67 L103 39"
                  fill="none"
                  stroke="#2563EB"
                  stroke-width="7"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <circle cx="64" cy="76" r="9.5" fill="#2563EB"></circle>
                <path d="M59.5 80 H68.5 L72 93 H56 Z" fill="#2563EB"></path>
              </svg>
              <h1 class="wordmark">MailKey</h1>
              <span class="chip-status">
                <span class="pulse" aria-hidden="true"></span>
                In development — preparing for Chrome Web Store review
              </span>
            </div>

            <p class="app-summary" data-reveal>
              MailKey is a Chrome extension that fills email verification
              codes for you.
            </p>

            <p class="title" data-lines>
              <span class="line"><span>The code you</span></span>
              <span class="line"><span>just asked for,</span></span>
              <span class="line"><span>one click away.</span></span>
            </p>

            <p class="lede" data-reveal data-reveal-delay="220">
              Apple's SMS autofill, moved to email. MailKey is a Chrome
              extension that reads only the last hour of your Gmail, finds the
              verification code that just arrived, and offers to fill it in.
              Nothing is stored, nothing is sent anywhere, and nothing happens
              until you click.
            </p>

            <dl class="facts" data-reveal data-reveal-delay="300">
              <div><dt>Platform</dt><dd>{project.platform}</dd></div>
              <div><dt>Access</dt><dd>Gmail, read-only</dd></div>
              <div><dt>Backend</dt><dd>None</dd></div>
            </dl>
          </div>

          <!-- Demo ------------------------------------------------------- -->
          <div class="hero-visual" data-tilt data-tilt-strength="5">
            <div class="visual-inner" data-wipe>
              <div
                class="demo"
                role="img"
                aria-label="A mock sign-in page showing MailKey's suggestion chip: the code 483920 from northwind.app, marked as matching the site, with a Fill button."
              >
                <div class="demo-site">
                  <div class="demo-bar">
                    <i></i><i></i><i></i>
                    <span class="url">northwind.app</span>
                  </div>

                  <p class="demo-label">Enter the 6-digit code we emailed you</p>
                  <div class="digits">
                    <span class="digit"><b>4</b></span>
                    <span class="digit"><b>8</b></span>
                    <span class="digit"><b>3</b></span>
                    <span class="digit"><b>9</b></span>
                    <span class="digit"><b>2</b></span>
                    <span class="digit"><b>0</b></span>
                  </div>

                  <div class="chip">
                    <span class="chip-mark" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2.6 4.8 5.4v5.1c0 4.4 3 8.4 7.2 9.9 4.2-1.5 7.2-5.5 7.2-9.9V5.4z"></path>
                        <circle cx="12" cy="9.4" r="2.4"></circle>
                        <path d="M12 11.8 11.2 16h1.6z"></path>
                      </svg>
                    </span>
                    <span class="chip-body">
                      <span class="chip-code">483920</span>
                      <span class="chip-meta">
                        from northwind.app
                        <span class="match">match</span>
                      </span>
                    </span>
                    <span class="chip-fill">Fill</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works ------------------------------------------------------ -->
    <section class="section how">
      <div class="shell">
        <div class="draw-rule"></div>
        <header class="head" data-lines>
          <span class="eyebrow line"><span>How it works</span></span>
          <h2 class="line"><span>Three moments, and only one of them is yours.</span></h2>
        </header>

        <ol class="steps" data-stagger style="--stagger-step:90ms">
          {steps.map((step, i) => (
            <li>
              <span class="step-n">{String(i + 1).padStart(2, '0')}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- What it does ------------------------------------------------------ -->
    <section class="section features">
      <div class="shell">
        <header class="head" data-lines>
          <span class="eyebrow line"><span>What it does</span></span>
          <h2 class="line"><span>Small surface, stated exactly.</span></h2>
        </header>

        <ul class="feat-list" data-stagger style="--stagger-step:55ms">
          {project.features?.map((feature) => <li>{feature}</li>)}
        </ul>
      </div>
    </section>

    <!-- Privacy ------------------------------------------------------------ -->
    <section class="section privacy">
      <div class="shell">
        <div class="privacy-panel" data-reveal data-spotlight>
          <div class="privacy-head">
            <span class="eyebrow">Privacy</span>
            <h2>The honest version.</h2>
            <p>
              MailKey exists because verification codes are annoying, not
              because anyone needs another thing reading their mail. So the
              constraints are written down — including the one Google cannot
              enforce for you.
            </p>
            <a class="policy-link" href="/mailkey/privacy">
              Read the full privacy policy <span aria-hidden="true">→</span>
            </a>
          </div>

          <dl class="guarantees" data-stagger style="--stagger-step:60ms">
            {guarantees.map((item) => (
              <div>
                <dt>{item.term}</dt>
                <dd>{item.detail}</dd>
              </div>
            ))}
          </dl>
        </div>

        <p class="caveat" data-reveal>
          <strong>One thing it is not:</strong> the domain shown next to a code
          is there so a mismatch is easy to notice. It is an aid to your own
          judgement, not phishing protection, and it is not described as
          protection anywhere in the product.
        </p>
      </div>
    </section>

    <!-- Meta + status ------------------------------------------------------ -->
    <section class="section closing">
      <div class="shell">
        <div class="meta-grid">
          <div data-reveal>
            <span class="eyebrow">What guided it</span>
            <ul class="principles" data-stagger style="--stagger-step:70ms">
              {project.principles?.map((p) => <li>{p}</li>)}
            </ul>
          </div>
          <div data-reveal data-reveal-delay="120">
            <span class="eyebrow">Built with</span>
            <div class="tech" data-stagger style="--stagger-step:45ms">
              {project.technologies.map((tech) => <span>{tech}</span>)}
            </div>
          </div>
        </div>

        <div class="status-band" data-reveal data-spotlight>
          <div>
            <span class="eyebrow">Availability</span>
            <p class="status-line">
              Not yet released. MailKey is being prepared for Chrome Web Store
              submission — it has not been reviewed, approved, or verified by
              Google, and there is nothing to install yet.
            </p>
          </div>
          <a class="cta" href="/contact">Ask me about it <span aria-hidden="true">→</span></a>
        </div>

        <a class="all-projects" href="/projects"><span aria-hidden="true">←</span> See all projects</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* The chrome stays neutral; MailKey brings the colour. -------------------- */
  .mailkey {
    --mk: #2563eb;
    --mk-ink: #ffffff;
    --match: #15803d;
    --match-bg: rgba(21, 128, 61, 0.1);
    --card-accent: var(--mk);
  }

  :global(:root[data-theme="dark"]) .mailkey {
    --mk: #4d82ff;
    --mk-ink: #08101f;
    --match: #5ee08d;
    --match-bg: rgba(94, 224, 141, 0.12);
  }

  /* Hero -------------------------------------------------------------------- */
  .hero {
    padding-top: clamp(2rem, 5vw, 3.5rem);
  }

  .back,
  .all-projects {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: gap 0.25s var(--ease-out), color 0.25s var(--ease-out);
  }

  .back {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .back:hover,
  .all-projects:hover {
    color: var(--text-primary);
    gap: 0.75rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .mark {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 0.65rem;
    box-shadow: 0 6px 18px color-mix(in srgb, #2563eb 28%, transparent);
  }

  .wordmark {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .app-summary {
    margin: 0 0 1.25rem;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .chip-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--mk) 35%, var(--border));
    border-radius: 99px;
    color: var(--text-secondary);
    font-size: 0.78rem;
    line-height: 1.3;
  }

  .pulse {
    flex-shrink: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--mk);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--mk) 18%, transparent);
  }

  .title {
    font-size: clamp(2.6rem, 5.4vw, 4.1rem);
    margin: 0 0 1.25rem;
  }

  .hero-copy .lede {
    max-width: 34rem;
    margin: 0;
  }

  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    margin: 2rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .facts dt {
    color: var(--text-tertiary);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .facts dd {
    margin: 0.35rem 0 0;
    font-weight: 550;
    font-size: 0.95rem;
  }

  .hero-visual {
    transform: perspective(1400px) rotateX(var(--tilt-rx, 0deg)) rotateY(var(--tilt-ry, 0deg));
    will-change: transform;
  }

  .visual-inner {
    border-radius: 1rem;
    overflow: hidden;
  }

  /* Demo -------------------------------------------------------------------- */
  .demo {
    display: grid;
    place-items: center;
    padding: clamp(1.75rem, 4vw, 3rem) clamp(1rem, 3vw, 2rem) clamp(3.5rem, 6vw, 4.5rem);
    border: 1px solid var(--border);
    border-radius: 1rem;
    /* Elevation ladder: stage → site card → chip. Reading darkest-to-lightest
       in dark, and shadow-separated in light, keeps the chip on top in both. */
    background:
      radial-gradient(circle at 72% 14%, color-mix(in srgb, var(--mk) 20%, transparent), transparent 58%),
      var(--background);
  }

  .demo-site {
    position: relative;
    width: min(100%, 22.5rem);
    /* The bottom padding is the chip's landing strip — without it the chip,
       which hangs off the card, would sit on top of the code field. */
    padding: 0.75rem 1.4rem 2.9rem;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: var(--surface);
    box-shadow: var(--shadow-lg);
  }

  .demo-bar {
    display: flex;
    align-items: center;
    gap: 0.32rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }

  .demo-bar i {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--text-tertiary);
  }

  .url {
    margin-left: 0.6rem;
    color: var(--text-tertiary);
    font-size: 0.68rem;
    letter-spacing: 0.01em;
  }

  .demo-label {
    margin: 1.25rem 0 0.75rem;
    color: var(--text-secondary);
    font-size: 0.75rem;
  }

  .digits {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.35rem;
  }

  .digit {
    display: grid;
    place-items: center;
    height: 2.5rem;
    border: 1px solid var(--border-strong);
    border-radius: 0.4rem;
    background: color-mix(in srgb, var(--background) 60%, var(--surface));
    font-size: 1rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .digit b {
    font-weight: inherit;
  }

  /* The suggestion chip, anchored under the field like the real one. */
  .chip {
    position: absolute;
    left: 1.4rem;
    right: 1.4rem;
    bottom: -1.6rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 0.6rem 0.6rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--mk) 30%, var(--border));
    border-radius: 0.7rem;
    background: var(--surface-elevated);
    box-shadow: var(--shadow-lg);
  }

  .chip-mark {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.45rem;
    background: var(--mk);
    color: var(--mk-ink);
  }

  .chip-mark svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .chip-body {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .chip-code {
    font-size: 1.05rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.12em;
  }

  .chip-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-tertiary);
    font-size: 0.66rem;
    white-space: nowrap;
  }

  .match {
    padding: 0.05rem 0.35rem;
    border-radius: 99px;
    background: var(--match-bg);
    color: var(--match);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .chip-fill {
    margin-left: auto;
    flex-shrink: 0;
    padding: 0.4rem 0.8rem;
    border-radius: 0.45rem;
    background: var(--mk);
    color: var(--mk-ink);
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Motion. The resting state above is the finished state, so switching the
     animations off (reduced motion) still leaves a complete, readable picture. */
  @media (prefers-reduced-motion: no-preference) {
    .chip {
      animation: chip-in 9s var(--ease-out) infinite;
    }

    .chip-fill {
      animation: fill-press 9s var(--ease-out) infinite;
    }

    .digit {
      animation: digit-box 9s var(--ease-out) infinite;
      animation-delay: calc(var(--d, 0) * 90ms);
    }

    .digit b {
      animation: digit-in 9s var(--ease-out) infinite;
      animation-delay: calc(var(--d, 0) * 90ms);
    }

    .digit:nth-child(2) { --d: 1; }
    .digit:nth-child(3) { --d: 2; }
    .digit:nth-child(4) { --d: 3; }
    .digit:nth-child(5) { --d: 4; }
    .digit:nth-child(6) { --d: 5; }
  }

  @keyframes chip-in {
    0%, 4% { opacity: 0; transform: translateY(10px) scale(0.98); }
    13%, 93% { opacity: 1; transform: none; }
    98%, 100% { opacity: 0; transform: translateY(6px) scale(0.99); }
  }

  @keyframes fill-press {
    0%, 46% { transform: none; }
    50% { transform: scale(0.93); }
    56%, 100% { transform: none; }
  }

  @keyframes digit-in {
    0%, 50% { opacity: 0; transform: translateY(5px); }
    57%, 94% { opacity: 1; transform: none; }
    99%, 100% { opacity: 0; transform: none; }
  }

  @keyframes digit-box {
    0%, 50% { border-color: var(--border-strong); }
    57%, 94% { border-color: color-mix(in srgb, var(--mk) 55%, var(--border-strong)); }
    99%, 100% { border-color: var(--border-strong); }
  }

  /* Shared section furniture ------------------------------------------------ */
  .draw-rule {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .head .eyebrow {
    margin-bottom: 0.9rem;
  }

  .head h2 {
    margin: 0;
    max-width: 20ch;
  }

  /* How it works ------------------------------------------------------------ */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 3rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .steps li {
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .step-n {
    display: block;
    margin-bottom: 0.9rem;
    color: var(--mk);
    font-size: 0.85rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
  }

  .steps h3 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.15rem, 1.8vw, 1.4rem);
  }

  .steps p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Features ---------------------------------------------------------------- */
  .features {
    padding-top: 0;
  }

  .feat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--border);
  }

  .feat-list li {
    position: relative;
    padding: clamp(0.9rem, 2vw, 1.25rem) 0 clamp(0.9rem, 2vw, 1.25rem) 1.75rem;
    border-bottom: 1px solid var(--border);
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    letter-spacing: -0.018em;
    transition: padding-left 0.35s var(--ease-out);
  }

  .feat-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 1.6em;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--mk);
  }

  .feat-list li:hover {
    padding-left: 2.25rem;
  }

  /* Privacy ----------------------------------------------------------------- */
  .privacy {
    padding-top: 0;
  }

  .privacy-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 5vw, 4rem);
    padding: clamp(1.75rem, 4vw, 3rem);
    border: 1px solid var(--border);
    border-radius: 1.1rem;
    background: var(--surface);
    overflow: hidden;
  }

  .privacy-head {
    position: relative;
    z-index: 1;
  }

  .privacy-head .eyebrow {
    margin-bottom: 0.9rem;
  }

  .privacy-head h2 {
    margin: 0 0 1rem;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .privacy-head p {
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 32ch;
  }

  .policy-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    color: var(--text-primary);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--mk) 45%, var(--border));
    padding-bottom: 0.15rem;
  }

  .policy-link span {
    color: var(--mk);
    transition: transform 0.25s var(--ease-out);
  }

  .policy-link:hover {
    border-color: var(--mk);
  }

  .policy-link:hover span {
    transform: translateX(4px);
  }

  .guarantees {
    position: relative;
    z-index: 1;
    margin: 0;
  }

  .guarantees > div {
    padding: 1rem 0;
    border-top: 1px solid var(--border);
  }

  .guarantees > div:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .guarantees dt {
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 0.35rem;
  }

  .guarantees dd {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .caveat {
    max-width: 52ch;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    padding-left: 1rem;
    border-left: 2px solid color-mix(in srgb, var(--mk) 50%, var(--border));
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .caveat strong {
    color: var(--text-primary);
