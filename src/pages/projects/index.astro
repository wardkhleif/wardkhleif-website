---
import BaseLayout from '../../layouts/BaseLayout.astro'; import ProjectCard from '../../components/ProjectCard.astro'; import { projects } from '../../data/projects';
---
<BaseLayout title="Projects — Ward Khleif" description="Explore Ward Khleif's iOS apps, browser extensions, automation systems, and digital product work."><section class="page-hero"><div class="shell"><p class="eyebrow">Projects</p><h1>Useful ideas, shaped into focused products.</h1><p>Work across mobile apps, browser extensions, and automation—each grounded in a real problem and presented honestly at its current stage.</p></div></section><section><div class="shell projects">{projects.map(project=><ProjectCard project={project}/>)}</div></section></BaseLayout>
<style>.page-hero{padding:7rem 0 5rem}.page-hero h1{font-size:clamp(3rem,8vw,6rem);max-width:13ch}.page-hero p:last-child{max-width:44rem;color:var(--text-secondary);font-size:1.15rem}.projects{display:grid;gap:1.25rem}.projects :global(article:nth-child(3)),.projects :global(article:nth-child(4)){grid-template-columns:.75fr 1.25fr}@media(max-width:720px){.projects :global(article:nth-child(3)),.projects :global(article:nth-child(4)){grid-template-columns:1fr}}</style>
