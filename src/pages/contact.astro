---
import BaseLayout from '../layouts/BaseLayout.astro'; import ButtonLink from '../components/ButtonLink.astro'; import { site } from '../data/site';
const hasContact=Boolean(site.email||site.linkedinUrl||site.githubUrl);
---
<BaseLayout title="Contact — Ward Khleif" description="Contact Ward Khleif about software opportunities, collaborations, technical conversations, and product feedback."><section class="contact"><div class="shell contact-grid"><div><p class="eyebrow">Contact</p><h1>Let’s build something useful.</h1><p class="lead">I’m open to software opportunities, product collaborations, technical conversations, and thoughtful feedback on my work.</p></div><aside>{hasContact ? <><h2>Start a conversation</h2><div class="links">{site.email&&<ButtonLink href={`mailto:${site.email}`}>Send an email</ButtonLink>}{site.linkedinUrl&&<ButtonLink href={site.linkedinUrl} variant="secondary">Connect on LinkedIn</ButtonLink>}{site.githubUrl&&<ButtonLink href={site.githubUrl} variant="secondary">View GitHub</ButtonLink>}</div></> : <><span aria-hidden="true">↗</span><h2>Contact links are being prepared.</h2><p>Public contact details will appear here when they’re ready. In the meantime, you can explore the work and learn more about what I build.</p><a href="/projects">Explore projects →</a></>}</aside></div></section></BaseLayout>
<style>.contact{padding:clamp(5rem,12vw,10rem) 0}.contact-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(3rem,8vw,8rem);align-items:center}.contact h1{font-size:clamp(3.5rem,9vw,7rem);max-width:10ch}.lead{font-size:1.2rem;color:var(--text-secondary);max-width:40rem}.contact aside{padding:clamp(1.5rem,4vw,3rem);border:1px solid var(--border);border-radius:1rem;background:var(--surface)}aside>span{font-size:2rem;color:var(--accent-bright)}aside h2{font-size:1.7rem;margin-top:2rem}aside p{color:var(--text-secondary)}aside a{font-weight:650}.links{display:flex;flex-direction:column;gap:.7rem;align-items:flex-start}@media(max-width:750px){.contact-grid{grid-template-columns:1fr}}</style>
