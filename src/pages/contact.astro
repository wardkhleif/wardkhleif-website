---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const channels = [
  { label: 'LinkedIn', handle: 'in/ward-khleif', href: site.linkedinUrl },
  { label: 'GitHub', handle: '@wardkhleif', href: site.githubUrl },
].filter((c) => c.href);

// Web3Forms access keys are public by design — they only permit posting to the
// inbox they were issued for. Set PUBLIC_WEB3FORMS_KEY in .env locally and in
// the Cloudflare Pages environment variables for production.
const formKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

// The address is deliberately hidden once the form works, to keep it away from
// scrapers. Without a key the form can't deliver anything, so we fall back to
// showing it — the page must never be a dead end.
const showEmailFallback = !formKey;
---

<BaseLayout
  title="Contact — Ward Khleif"
  description="Send Ward Khleif a message, or connect on LinkedIn and GitHub."
>
  <section class="section contact">
    <div class="shell contact-grid">
      <div class="intro">
        <header class="head" data-lines>
          <span class="eyebrow line"><span>Contact</span></span>
          <h1 class="line"><span>Let's build</span></h1>
          <h1 class="line"><span>something.</span></h1>
        </header>

        <p class="lede" data-reveal data-reveal-delay="200">
          Have an idea, a question, or just want to say hello? Send it over —
          I read everything.
        </p>

        {showEmailFallback && (
          <p class="fallback" data-reveal data-reveal-delay="260">
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </p>
        )}

        {channels.length > 0 && (
          <div class="channels" data-stagger style="--stagger-step:90ms">
            {channels.map((c) => (
              <a class="channel" href={c.href} target="_blank" rel="noreferrer">
                <span class="channel-label">{c.label}</span>
                <span class="channel-handle">{c.handle}</span>
                <span class="channel-arrow" aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        )}

        <p class="availability" data-reveal data-reveal-delay="120">
          <span class="dot" aria-hidden="true"></span>
          Open to internships and interesting projects.
        </p>
      </div>

      <div class="form-wrap" data-reveal data-reveal-delay="180">
        {formKey ? (
          <form class="form" id="contact-form" novalidate>
            <input type="hidden" name="access_key" value={formKey} />
            <input type="hidden" name="subject" value="New message from wardkhleif.com" />
            <input type="hidden" name="from_name" value="wardkhleif.com" />

            {/* Honeypot — bots fill it, humans never see it. */}
            <input
              type="checkbox"
              name="botcheck"
              class="botcheck"
              tabindex="-1"
              autocomplete="off"
            />

            {/* The " " placeholders are load-bearing: :placeholder-shown is how
                the CSS tells an untouched field from a genuinely invalid one. */}
            <div class="field">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder=" " />
            </div>

            <div class="field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder=" " />
            </div>

            <div class="field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required placeholder=" "></textarea>
            </div>

            <button type="submit" class="submit">
              <span class="submit-label">Send message</span>
              <span class="arrow" aria-hidden="true">→</span>
            </button>

            <!-- Announced to screen readers as it changes. -->
            <p class="status" role="status" aria-live="polite"></p>
          </form>
        ) : (
          <div class="form-placeholder">
            <p><strong>The message form isn't live yet.</strong></p>
            <p>
              Add a Web3Forms access key as <code>PUBLIC_WEB3FORMS_KEY</code> to
              turn it on. Until then, email works fine.
            </p>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('#contact-form');

  if (form) {
    const status = form.querySelector<HTMLParagraphElement>('.status')!;
    const button = form.querySelector<HTMLButtonElement>('.submit')!;
    const label = button.querySelector<HTMLSpanElement>('.submit-label')!;

    const setStatus = (message: string, kind: '' | 'error' | 'ok' = '') => {
      status.textContent = message;
      status.className = `status${kind ? ` is-${kind}` : ''}`;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      // Validate here rather than relying on the browser bubble, so the
      // message matches the rest of the page's voice.
      if (!form.checkValidity()) {
        const firstInvalid = form.querySelector<HTMLInputElement>(':invalid');
        firstInvalid?.focus();
        setStatus('Please fill in every field with a valid email.', 'error');
        return;
      }

      button.disabled = true;
      label.textContent = 'Sending';
      setStatus('');

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });
        const result = await response.json();

        if (response.ok && result.success) {
          form.classList.add('is-sent');
          setStatus("Thanks — your message is on its way. I'll get back to you soon.", 'ok');
          form.reset();
        } else {
          throw new Error(result.message || 'Request failed');
        }
      } catch {
        setStatus(
          "Something went wrong and the message didn't send. Please try again in a moment.",
          'error'
        );
      } finally {
        button.disabled = false;
        label.textContent = 'Send message';
      }
    });
  }
</script>

<style>
  .contact {
    min-height: calc(100svh - 4.25rem);
    display: grid;
    align-content: center;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 7vw, 6rem);
    align-items: start;
  }

  .head {
    margin-bottom: 1.5rem;
  }

  .head .eyebrow {
    margin-bottom: 1rem;
  }

  .head h1 {
    margin: 0;
    line-height: 0.92;
  }

  .lede {
    max-width: 30rem;
    margin: 0 0 2rem;
  }

  .fallback {
    margin: 0 0 2rem;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .fallback a {
    color: var(--text-primary);
    text-decoration-color: var(--border-strong);
    text-underline-offset: 0.25em;
  }

  /* Secondary channels. */
  .channels {
    display: grid;
    gap: 1px;
    background: var(--border);
    border-block: 1px solid var(--border);
  }

  .channel {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.15rem 0.25rem;
    background: var(--background);
    text-decoration: none;
    color: var(--text-primary);
    transition: padding-left 0.3s var(--ease-out);
  }

  .channel:hover {
    padding-left: 0.75rem;
  }

  .channel-label {
    font-weight: 600;
    font-size: 1.05rem;
  }

  .channel-handle {
    color: var(--text-secondary);
    font-size: 0.92rem;
  }

  .channel-arrow {
    margin-left: auto;
    color: var(--text-tertiary);
    transition: transform 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }

  .channel:hover .channel-arrow {
    transform: translate(3px, -3px);
    color: var(--accent-bright);
  }

  .availability {
    display: flex;
    /* Pin to the first line — centring drifts once the text wraps. */
    align-items: flex-start;
    gap: 0.6rem;
    margin: 1.75rem 0 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .availability .dot {
    flex-shrink: 0;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: 0.5em;
    border-radius: 50%;
    background: #23c7b8;
    box-shadow: 0 0 0 4px color-mix(in srgb, #23c7b8 18%, transparent);
  }

  /* ---- Form ------------------------------------------------------------- */
  .form {
    display: grid;
    gap: 1.75rem;
  }

  .field {
    display: grid;
    gap: 0.5rem;
  }

  .field label {
    color: var(--text-tertiary);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  /* Underlined inputs rather than boxes — closer to the page's editorial feel. */
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.6rem 0;
    border: 0;
    border-bottom: 1px solid var(--border-strong);
    background: transparent;
    color: var(--text-primary);
    font: inherit;
    font-size: 1.05rem;
    border-radius: 0;
    transition: border-color 0.3s var(--ease-out);
  }

  .field textarea {
    resize: vertical;
    min-height: 6rem;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-bottom-color: var(--text-primary);
  }

  /* The browser's :invalid matches before the user has typed anything, so only
     flag a field once it has been interacted with and left. */
  .field input:not(:placeholder-shown):invalid,
  .field textarea:not(:placeholder-shown):invalid {
    border-bottom-color: #e5484d;
  }

  .botcheck {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .submit {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.6rem;
    border: 0;
    border-radius: 99px;
    background: var(--text-primary);
    color: var(--background);
    font: inherit;
    font-weight: 650;
    cursor: pointer;
    transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out);
  }

  .submit:hover:not(:disabled) {
    transform: translateY(-2px);
  }

  .submit:disabled {
    opacity: 0.55;
    cursor: progress;
  }

  .submit .arrow {
    transition: transform 0.25s var(--ease-out);
  }

  .submit:hover:not(:disabled) .arrow {
    transform: translateX(4px);
  }

  .status {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .status:empty {
    display: none;
  }

  .status.is-error {
    color: #e5484d;
  }

  .status.is-ok {
    color: #16a34a;
  }

  /* Once sent, retire the fields and let the confirmation stand alone. */
  .form.is-sent .field,
  .form.is-sent .submit {
    display: none;
  }

  .form-placeholder {
    padding: 1.5rem;
    border: 1px dashed var(--border-strong);
    border-radius: 0.9rem;
    color: var(--text-secondary);
  }

  .form-placeholder p {
    margin: 0 0 0.6rem;
  }

  .form-placeholder p:last-child {
    margin-bottom: 0;
  }

  .form-placeholder code {
    font-size: 0.85em;
    padding: 0.15em 0.4em;
    border-radius: 0.3rem;
    background: var(--surface-elevated);
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .contact {
      align-content: start;
    }
  }
</style>
