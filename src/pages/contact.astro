---
import BaseLayout from '../layouts/BaseLayout.astro';
import ButtonLink from '../components/ButtonLink.astro';
import Monogram from '../components/Monogram.astro';
import { site } from '../data/site';

const hasContact = Boolean(site.email || site.linkedinUrl || site.githubUrl);
const paths = [
  { number: '01', title: 'Software opportunities', text: 'Roles and projects where product thinking, engineering, and thoughtful execution matter.' },
  { number: '02', title: 'Product collaboration', text: 'Focused ideas that need a technical partner to shape the core and build the experience.' },
  { number: '03', title: 'Technical conversation', text: 'A useful exchange about mobile apps, browser workflows, automation, or product craft.' },
  { number: '04', title: 'Thoughtful feedback', text: 'Specific observations that can make an app, extension, or interaction meaningfully better.' },
];
---

<BaseLayout title="Contact — Ward Khleif" description="Contact Ward Khleif about software opportunities, collaborations, technical conversations, and product feedback.">
  <section class="hero contact-hero">
    <div class="contact-beam" aria-hidden="true"></div>
    <div class="shell hero-grid contact-grid">
      <div class="contact-copy">
        <p class="eyebrow contact-enter delay-one">Contact / Start a conversation</p>
        <h1 aria-label="Let’s build something useful.">
          <span class="line-mask"><span>Let’s build&nbsp;</span></span>
          <span class="line-mask"><span>something <em>useful.</em></span></span>
        </h1>
        <p class="lead contact-enter delay-three">I’m open to software opportunities, product collaborations, technical conversations, and thoughtful feedback on my work.</p>
        <div class="contact-enter delay-four">
          {hasContact ? <div class="hero-actions">
            {site.email && <ButtonLink href={`mailto:${site.email}`}>Send an email</ButtonLink>}
            {site.linkedinUrl && <ButtonLink href={site.linkedinUrl} variant="secondary">Connect on LinkedIn</ButtonLink>}
            {site.githubUrl && <ButtonLink href={site.githubUrl} variant="secondary">View GitHub</ButtonLink>}
          </div> : <a class="availability" href="#contact-status"><i></i><span>Public contact channel coming soon</span><b aria-hidden="true">↓</b></a>}
        </div>
      </div>

      <div class="signal-field contact-enter delay-two" aria-hidden="true" data-parallax>
        <div class="signal-glow"></div>
        <div class="signal-ring ring-one"><i></i></div>
        <div class="signal-ring ring-two"><i></i></div>
        <div class="signal-ring ring-three"></div>
        <div class="signal-core"><Monogram size="5rem" /><span>OPEN TO<br/>GOOD IDEAS</span></div>
        <div class="signal-label label-build"><i></i>Build</div>
        <div class="signal-label label-talk"><i></i>Talk</div>
        <div class="signal-label label-shape"><i></i>Shape</div>
        <div class="signal-sweep"></div>
      </div>
    </div>

    <div class="question-rail" aria-hidden="true"><div>
      <span>WHAT ARE WE SOLVING?</span><i>✦</i><span>WHY DOES IT MATTER?</span><i>✦</i><span>WHAT SHOULD FEEL SIMPLER?</span><i>✦</i><span>WHAT ARE WE SOLVING?</span><i>✦</i><span>WHY DOES IT MATTER?</span><i>✦</i><span>WHAT SHOULD FEEL SIMPLER?</span><i>✦</i>
    </div></div>
  </section>

  <section class="contact-paths">
    <div class="shell">
      <div class="paths-heading" data-reveal><p class="eyebrow">Good reasons to reach out</p><h2>A useful conversation can start in a few different places.</h2></div>
      <div class="path-list">{paths.map(path => <article data-reveal><span>{path.number}</span><h3>{path.title}</h3><p>{path.text}</p><i aria-hidden="true">↗</i></article>)}</div>
    </div>
  </section>

  <section class="contact-principle">
    <div class="shell principle-grid">
      <div class="principle-mark" aria-hidden="true" data-reveal><span>?</span><i></i><i></i><i></i></div>
      <div data-reveal><p class="eyebrow">The best starting point</p><h2>Bring the problem—not a polished pitch.</h2><p>Context, constraints, and the part that currently feels difficult are usually more valuable than a finished solution. Good products begin by understanding what actually needs to change.</p></div>
    </div>
  </section>

  <section class="contact-status" id="contact-status">
    <div class="shell status-card" data-reveal>
      <div class="status-orbit" aria-hidden="true"><i></i><i></i><span><Monogram size="3rem" /></span></div>
      <div>
        <p class="eyebrow">Contact status</p>
        {hasContact ? <><h2>The channel is open.</h2><p>Choose the contact method that works best and include whatever context will help start a useful conversation.</p><div class="status-actions">{site.email && <ButtonLink href={`mailto:${site.email}`}>Send an email</ButtonLink>}{site.linkedinUrl && <ButtonLink href={site.linkedinUrl} variant="secondary">LinkedIn</ButtonLink>}{site.githubUrl && <ButtonLink href={site.githubUrl} variant="secondary">GitHub</ButtonLink>}</div></> : <><h2>The public channel is being prepared.</h2><p>I’m setting up the right place for thoughtful messages. No broken form, fake address, or inbox that goes nowhere—in the meantime, the work is here to explore.</p><ButtonLink href="/projects">Explore the work</ButtonLink></>}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero{min-height:calc(100svh - 4.6rem);position:relative;display:grid;align-items:center;padding:5rem 0 0;overflow:hidden;isolation:isolate}.contact-beam{position:absolute;z-index:-1;inset:-40% 0 auto 48%;width:1px;height:160%;background:linear-gradient(transparent,var(--accent-bright),transparent);opacity:.14;transform:rotate(28deg);box-shadow:0 0 100px 40px color-mix(in srgb,var(--accent) 8%,transparent)}.contact-grid{display:grid;grid-template-columns:1.12fr .88fr;gap:clamp(3rem,8vw,8rem);align-items:center;transform:translateY(var(--hero-y,0)) scale(var(--hero-scale,1));opacity:var(--hero-opacity,1);filter:blur(var(--hero-blur,0));will-change:transform,opacity,filter}.contact-copy{position:relative;z-index:2}.contact-copy h1{font-size:clamp(4rem,9vw,8.2rem);line-height:.88;max-width:10ch;margin:.8rem 0 2rem}.line-mask{display:block;overflow:hidden;padding:.08em 0}.line-mask>span{display:block;animation:line-up 1s cubic-bezier(.16,1,.3,1) both}.line-mask:nth-child(2)>span{animation-delay:.12s}.contact-copy h1 em{font-style:normal;color:transparent;-webkit-text-stroke:1px var(--text-primary);position:relative}.contact-copy h1 em:after{content:"";position:absolute;left:0;right:0;bottom:.05em;height:.08em;background:var(--accent-bright);transform:scaleX(0);transform-origin:left;animation:underline-in .8s cubic-bezier(.16,1,.3,1) .8s forwards}.lead{font-size:clamp(1.05rem,2vw,1.25rem);color:var(--text-secondary);line-height:1.75;max-width:39rem}.contact-enter{animation:contact-in .85s cubic-bezier(.22,1,.36,1) both}.delay-one{animation-delay:.04s}.delay-two{animation-delay:.22s}.delay-three{animation-delay:.38s}.delay-four{animation-delay:.52s}.hero-actions{display:flex;gap:.7rem;flex-wrap:wrap;margin-top:2rem}.availability{display:inline-flex;align-items:center;gap:.7rem;margin-top:1.5rem;padding:.75rem 1rem;border:1px solid var(--border);border-radius:99px;text-decoration:none;color:var(--text-secondary);background:color-mix(in srgb,var(--surface) 70%,transparent);backdrop-filter:blur(15px)}.availability i{width:.5rem;height:.5rem;border-radius:50%;background:var(--accent-bright);box-shadow:0 0 0 5px color-mix(in srgb,var(--accent-bright) 12%,transparent),0 0 16px var(--accent-bright);animation:status-pulse 2s ease-in-out infinite}.availability b{color:var(--accent-bright);font-weight:400;margin-left:.4rem;animation:arrow-down 1.8s ease-in-out infinite}.signal-field{aspect-ratio:1;position:relative;display:grid;place-items:center;transform:translate3d(var(--parallax-x,0),var(--parallax-y,0),0)}.signal-glow{position:absolute;inset:20%;border-radius:50%;background:var(--accent);opacity:.16;filter:blur(85px);animation:signal-breathe 4.5s ease-in-out infinite}.signal-ring{position:absolute;border:1px solid var(--border);border-radius:50%}.ring-one{inset:12%;animation:signal-spin 22s linear infinite}.ring-two{inset:0;border-style:dashed;animation:signal-spin 36s linear infinite reverse}.ring-three{inset:27%;opacity:.7;animation:signal-spin 14s linear infinite}.signal-ring>i{position:absolute;top:9%;left:20%;width:.5rem;height:.5rem;border-radius:50%;background:var(--accent-bright);box-shadow:0 0 18px var(--accent-bright)}.ring-two>i{top:auto;left:auto;right:11%;bottom:20%;width:.35rem;height:.35rem}.signal-core{position:relative;z-index:3;width:9.5rem;height:9.5rem;border-radius:2.3rem;display:grid;place-items:center;background:var(--text-primary);color:var(--background);box-shadow:0 35px 90px rgba(0,0,0,.38);animation:core-float 5s ease-in-out infinite;overflow:hidden}.signal-core:after{content:"";position:absolute;inset:-80%;background:linear-gradient(110deg,transparent 40%,rgba(255,255,255,.35),transparent 60%);animation:core-sheen 6s ease-in-out infinite}.signal-core strong{font-size:2.7rem;letter-spacing:-.1em}.signal-core span{position:absolute;bottom:1rem;font:600 .48rem/1.25 monospace;letter-spacing:.08em;text-align:center;opacity:.58}.signal-label{position:absolute;z-index:4;display:flex;align-items:center;gap:.5rem;padding:.6rem .8rem;border:1px solid var(--border);border-radius:.65rem;background:color-mix(in srgb,var(--surface) 78%,transparent);backdrop-filter:blur(16px);color:var(--text-secondary);font-size:.72rem;box-shadow:0 16px 38px rgba(0,0,0,.16);animation:label-float 4s ease-in-out infinite}.signal-label i{width:.4rem;height:.4rem;border-radius:50%;background:var(--accent-bright);box-shadow:0 0 9px var(--accent-bright)}.label-build{left:0;top:29%}.label-talk{right:0;top:20%;animation-delay:-1.3s}.label-shape{right:7%;bottom:16%;animation-delay:-2.6s}.signal-sweep{position:absolute;inset:8%;border-radius:50%;overflow:hidden;animation:signal-spin 5s linear infinite}.signal-sweep:before{content:"";position:absolute;left:50%;top:50%;width:50%;height:1px;background:linear-gradient(90deg,var(--accent-bright),transparent);transform-origin:left}.question-rail{grid-column:1/-1;margin-top:auto;overflow:hidden;border-block:1px solid var(--border);padding:.85rem 0;color:var(--text-secondary);font:600 .67rem/1 monospace;letter-spacing:.14em;white-space:nowrap}.question-rail>div{display:inline-flex;min-width:max-content;align-items:center;gap:2rem;animation:rail-move 30s linear infinite}.question-rail i{color:var(--accent-bright);font-style:normal}.contact-paths{padding:8rem 0}.paths-heading{display:grid;grid-template-columns:.65fr 1.35fr;gap:3rem;align-items:start;margin-bottom:4rem}.paths-heading h2{max-width:15ch}.path-list{border-top:1px solid var(--border)}.path-list article{display:grid;grid-template-columns:4rem 1.1fr 1.7fr 2rem;gap:1.5rem;align-items:center;padding:2rem 0;border-bottom:1px solid var(--border);transition:padding .3s,background .3s}.path-list article:hover{padding-inline:1rem;background:var(--surface)}.path-list article>span{color:var(--accent-bright);font: .75rem monospace}.path-list h3{margin:0;font-size:1.2rem}.path-list p{margin:0;color:var(--text-secondary)}.path-list article>i{font-style:normal;color:var(--accent-bright);transition:transform .25s}.path-list article:hover>i{transform:translate(4px,-4px)}.contact-principle{padding:8rem 0;background:var(--surface)}.principle-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(3rem,9vw,9rem);align-items:center}.principle-grid h2{max-width:12ch}.principle-grid p:last-child{color:var(--text-secondary);font-size:1.08rem;line-height:1.8;max-width:40rem}.principle-mark{aspect-ratio:1;position:relative;display:grid;place-items:center}.principle-mark>span{z-index:2;width:8rem;height:8rem;border-radius:2rem;display:grid;place-items:center;background:var(--text-primary);color:var(--background);font-size:3rem;font-weight:750;box-shadow:0 30px 70px rgba(0,0,0,.25)}.principle-mark i{position:absolute;border:1px solid var(--border);border-radius:50%;animation:signal-spin 25s linear infinite}.principle-mark i:nth-of-type(1){inset:12%}.principle-mark i:nth-of-type(2){inset:26%;border-style:dashed;animation-direction:reverse}.principle-mark i:nth-of-type(3){width:.65rem;height:.65rem;background:var(--accent-bright);border:0;box-shadow:0 0 16px var(--accent-bright);top:13%;left:27%}.contact-status{padding:8rem 0}.status-card{display:grid;grid-template-columns:.7fr 1.3fr;gap:clamp(3rem,8vw,8rem);align-items:center;padding:clamp(2rem,6vw,5rem);border:1px solid var(--border);border-radius:1.2rem;background:radial-gradient(circle at 10% 100%,color-mix(in srgb,var(--accent) 16%,transparent),transparent 40%),var(--surface)}.status-card h2{max-width:15ch}.status-card>div:last-child>p:not(.eyebrow){max-width:40rem;color:var(--text-secondary);line-height:1.8}.status-orbit{aspect-ratio:1;position:relative;display:grid;place-items:center}.status-orbit i{position:absolute;border:1px solid var(--border);border-radius:50%}.status-orbit i:first-child{inset:4%;animation:signal-spin 25s linear infinite}.status-orbit i:nth-child(2){inset:22%;border-style:dashed;animation:signal-spin 17s linear infinite reverse}.status-orbit span{width:5rem;height:5rem;border-radius:1.3rem;background:var(--text-primary);color:var(--background);display:grid;place-items:center;font-size:1.4rem;font-weight:800;box-shadow:0 20px 45px rgba(0,0,0,.25)}.status-actions{display:flex;flex-wrap:wrap;gap:.7rem;margin-top:1.5rem}@keyframes line-up{from{opacity:0;transform:translateY(115%)}to{opacity:1;transform:none}}@keyframes underline-in{to{transform:scaleX(1)}}@keyframes contact-in{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}@keyframes signal-spin{to{transform:rotate(1turn)}}@keyframes signal-breathe{50%{opacity:.26;transform:scale(1.15)}}@keyframes core-float{50%{transform:translateY(-8px) rotate(1.5deg)}}@keyframes core-sheen{0%,55%{transform:translateX(-70%) rotate(12deg)}85%,100%{transform:translateX(70%) rotate(12deg)}}@keyframes label-float{50%{transform:translateY(-8px)}}@keyframes status-pulse{50%{opacity:.55;transform:scale(.85)}}@keyframes arrow-down{50%{transform:translateY(4px)}}@keyframes rail-move{to{transform:translateX(-50%)}}@media(max-width:800px){.contact-hero{padding-top:3rem}.contact-grid{grid-template-columns:1fr;transform:none!important;opacity:1!important;filter:none!important}.signal-field{order:-1;width:min(100%,28rem);margin:auto}.contact-copy h1{font-size:clamp(3.6rem,16vw,5.3rem)}.paths-heading,.principle-grid,.status-card{grid-template-columns:1fr}.path-list article{grid-template-columns:2.5rem 1fr 1.5rem}.path-list article p{grid-column:2/-1}.principle-mark{width:min(100%,26rem);margin:auto}.status-orbit{width:min(65%,18rem);margin:auto}}@media(max-width:500px){.contact-hero{min-height:auto}.signal-label{font-size:.65rem}.contact-paths,.contact-principle,.contact-status{padding:5rem 0}.paths-heading{gap:1rem;margin-bottom:2rem}.path-list article{gap:.8rem}.status-card{padding:1.5rem}}
</style>
