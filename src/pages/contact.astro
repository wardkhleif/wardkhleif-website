---
import BaseLayout from '../layouts/BaseLayout.astro';
import Monogram from '../components/Monogram.astro';
import { site } from '../data/site';

const contacts = [
  { label: 'Email', value: site.email, href: site.email ? `mailto:${site.email}` : '' },
  { label: 'LinkedIn', value: site.linkedinUrl, href: site.linkedinUrl },
  { label: 'GitHub', value: site.githubUrl, href: site.githubUrl },
];
---

<BaseLayout title="Contact — Ward Khleif" description="Email Ward Khleif or connect on LinkedIn and GitHub.">
  <section class="contact-page">
    <div class="shell contact-layout">
      <div class="contact-intro">
        <p class="eyebrow">Contact</p>
        <h1>Let’s talk.</h1>
        <p>For opportunities, collaborations, or questions about my work.</p>
      </div>

      <div class="contact-panel">
        <div class="panel-mark" aria-hidden="true"><Monogram size="4.8rem" /></div>
        <div class="contact-list">
          {contacts.map((contact, index) => contact.href ? (
            <a href={contact.href} target={contact.label === 'Email' ? undefined : '_blank'} rel={contact.label === 'Email' ? undefined : 'noreferrer'}>
              <span>0{index + 1}</span><strong>{contact.label}</strong><small>{contact.value}</small><i aria-hidden="true">↗</i>
            </a>
          ) : (
            <div class="contact-link pending">
              <span>0{index + 1}</span><strong>{contact.label}</strong><small>Link coming soon</small><i aria-hidden="true">—</i>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page{min-height:calc(100svh - 4.6rem);display:grid;align-items:center;padding:clamp(4rem,10vw,8rem) 0;position:relative;overflow:hidden}.contact-page:before{content:"";position:absolute;width:38rem;height:38rem;right:-12rem;top:-16rem;border-radius:50%;background:var(--accent);filter:blur(150px);opacity:.1;pointer-events:none}.contact-layout{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(3rem,9vw,9rem);align-items:center}.contact-intro h1{font-size:clamp(4.8rem,11vw,10rem);line-height:.84;margin:.7rem 0 2rem;letter-spacing:-.07em}.contact-intro>p:last-child{max-width:30rem;color:var(--text-secondary);font-size:clamp(1.05rem,2vw,1.25rem);line-height:1.7}.contact-panel{border:1px solid var(--border);border-radius:1.2rem;background:color-mix(in srgb,var(--surface) 82%,transparent);box-shadow:0 30px 90px rgba(0,0,0,.14);overflow:hidden}.panel-mark{height:14rem;display:grid;place-items:center;color:var(--background);background:var(--text-primary);position:relative}.panel-mark:after{content:"";position:absolute;inset:-100%;background:linear-gradient(110deg,transparent 43%,rgba(255,255,255,.18),transparent 57%);animation:sheen 6s ease-in-out infinite}.contact-list{display:grid}.contact-list>a,.contact-link{display:grid;grid-template-columns:2.5rem 1fr minmax(7rem,1.2fr) 1.5rem;gap:1rem;align-items:center;min-height:5.25rem;padding:1rem 1.4rem;border-top:1px solid var(--border);color:var(--text-primary);text-decoration:none;transition:background .25s,padding .25s}.contact-list>a:hover{background:var(--surface-elevated);padding-inline:1.7rem}.contact-list span{color:var(--accent-bright);font:.7rem monospace}.contact-list strong{font-size:1.05rem}.contact-list small{color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.contact-list i{font-style:normal;color:var(--accent-bright)}.pending{opacity:.68}.pending i{color:var(--text-secondary)}@keyframes sheen{0%,55%{transform:translateX(-70%) rotate(12deg)}85%,100%{transform:translateX(70%) rotate(12deg)}}@media(max-width:760px){.contact-layout{grid-template-columns:1fr;gap:2.5rem}.contact-intro h1{font-size:clamp(4rem,22vw,6.5rem)}.panel-mark{height:11rem}.contact-list>a,.contact-link{grid-template-columns:2rem 1fr 1.5rem}.contact-list small{grid-column:2/4;grid-row:2}.contact-list i{grid-column:3;grid-row:1}}
</style>
