---
import BaseLayout from '../layouts/BaseLayout.astro';
const builds=['iOS apps','Browser extensions','Automation systems','Web experiences']; const steps=['Understand the problem','Reduce unnecessary complexity','Build a reliable core','Refine the experience','Publish and improve'];
---
<BaseLayout title="About — Ward Khleif" description="Learn how independent software developer Ward Khleif approaches apps, extensions, automation, and thoughtful product design."><section class="about-hero"><div class="shell"><p class="eyebrow">About</p><h1>I like building software that makes complicated things feel simple.</h1><div class="intro"><p>I’m Ward Khleif, a software developer working across mobile apps, browser extensions, websites, and automation systems.</p><p>My projects usually begin with a problem I experience directly: an overloaded photo library, repetitive browser workflows, or business tasks that should not require hours of manual work.</p><p>I care about the full product—not only whether the code works. That includes the interaction design, performance, privacy, reliability, onboarding, and the way the final result is presented.</p></div></div></section><section><div class="shell split"><div><p class="eyebrow">What I build</p><h2>Across platforms,<br/>with one standard.</h2></div><ul>{builds.map((item,i)=><li><span>0{i+1}</span>{item}</li>)}</ul></div></section><section><div class="shell process"><p class="eyebrow">How I work</p><h2>A clear path from problem to product.</h2><ol>{steps.map((step,i)=><li data-reveal><span>{String(i+1).padStart(2,'0')}</span><h3>{step}</h3></li>)}</ol></div></section></BaseLayout>
<style>.about-hero{padding:7rem 0}.about-hero h1{font-size:clamp(3rem,8vw,6.5rem);max-width:15ch}.intro{margin:4rem 0 0 auto;max-width:43rem}.intro p{color:var(--text-secondary);font-size:1.15rem;line-height:1.8}.split{border-top:1px solid var(--border);padding:6rem 0;display:grid;grid-template-columns:1fr 1fr;gap:5rem}.split ul{list-style:none;margin:0;padding:0}.split li{font-size:1.45rem;padding:1.2rem 0;border-bottom:1px solid var(--border)}.split li span{color:var(--accent-bright);font: .8rem monospace;margin-right:1rem}.process{padding:6rem 0}.process h2{max-width:14ch}.process ol{list-style:none;padding:0;margin-top:3rem;border-top:1px solid var(--border)}.process li{display:grid;grid-template-columns:5rem 1fr;align-items:center;border-bottom:1px solid var(--border);padding:1.4rem 0}.process li span{color:var(--accent-bright);font-family:monospace}.process h3{margin:0}@media(max-width:700px){.split{grid-template-columns:1fr;gap:2rem}.about-hero{padding:5rem 0}.intro{margin-top:2rem}}</style>
