---
import BaseLayout from './BaseLayout.astro';
import ProductPreview from '../components/ProductPreview.astro';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  problem: string;
  solution: string;
}

const { project, problem, solution } = Astro.props;

const links = [
  project.externalUrl && { label: 'Visit', href: project.externalUrl },
  project.repositoryUrl && { label: 'Source', href: project.repositoryUrl },
].filter(Boolean) as { label: string; href: string }[];
---

<BaseLayout
  title={`${project.name} — Ward Khleif`}
  description={project.shortDescription}
  breadcrumbs={[
    { name: 'Projects', href: '/projects' },
    { name: project.name, href: project.detailUrl || '/projects' },
  ]}
>
  <article class="project" style={`--card-accent:${project.accent}`}>
    <!-- Hero ----------------------------------------------------------------->
    <section class="section hero">
      <div class="shell">
        <a class="back" href="/projects">
          <span aria-hidden="true">←</span> Projects
        </a>

        <div class="hero-grid">
          <div class="hero-copy">
            <div class="tags-top" data-reveal>
              <span class="platform">{project.platform}</span>
              <span class="status"><span class="dot" aria-hidden="true"></span>{project.status}</span>
            </div>

            <h1 class="title" data-lines>
              <span class="line"><span>{project.name}</span></span>
            </h1>

            {project.subtitle && <p class="subtitle" data-reveal data-reveal-delay="120">{project.subtitle}</p>}
            <p class="lead lede" data-reveal data-reveal-delay="200">{project.shortDescription}</p>

            {links.length > 0 && (
              <div class="hero-links" data-reveal data-reveal-delay="300">
                {links.map((link) => (
                  <a href={link.href} target="_blank" rel="noreferrer">
                    {link.label} <span aria-hidden="true">↗</span>
                  </a>
                ))}
              </div>
            )}
          </div>

          <div class="hero-visual">
            <div class="visual-inner" data-wipe>
              <ProductPreview type={project.preview} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem + approach --------------------------------------------------->
    <section class="section narrative">
      <div class="shell">
        <div class="draw-rule"></div>
        <div class="narrative-grid">
          <div class="block" data-reveal>
            <span class="eyebrow">The problem</span>
            <p>{problem}</p>
          </div>
          <div class="block" data-reveal data-reveal-delay="120">
            <span class="eyebrow">The approach</span>
            <p>{solution}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features ------------------------------------------------------------->
    {project.features && project.features.length > 0 && (
      <section class="section features">
        <div class="shell">
          <header class="feat-head" data-lines>
            <span class="eyebrow line"><span>What it does</span></span>
            <h2 class="line"><span>Built around the real workflow.</span></h2>
          </header>
          <ol class="feat-list" data-stagger style="--stagger-step:60ms">
            {project.features.map((feature, i) => (
              <li>
                <span class="feat-index">{String(i + 1).padStart(2, '0')}</span>
                <span class="feat-text">{feature}</span>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}

    <!-- Principles + tech ---------------------------------------------------->
    <section class="section meta">
      <div class="shell meta-grid">
        {project.principles && project.principles.length > 0 && (
          <div class="block" data-reveal>
            <span class="eyebrow">What guided it</span>
            <ul class="principles" data-stagger style="--stagger-step:70ms">
              {project.principles.map((p) => <li>{p}</li>)}
            </ul>
          </div>
        )}

        <div class="block" data-reveal data-reveal-delay="120">
          <span class="eyebrow">Built with</span>
          <div class="tech" data-stagger style="--stagger-step:45ms">
            {project.technologies.map((tech) => <span>{tech}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- Status + CTA --------------------------------------------------------->
    <section class="section closing">
      <div class="shell">
        <div class="status-band" data-reveal data-spotlight>
          <div>
            <span class="eyebrow">Where it's at</span>
            <p class="status-line">{project.status}. Being built deliberately — no availability or approval is implied yet.</p>
          </div>
          <a class="cta" href="/contact">
            Ask me about it <span aria-hidden="true">→</span>
          </a>
        </div>

        <a class="all-projects" href="/projects">
          <span aria-hidden="true">←</span> See all projects
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* Hero -------------------------------------------------------------------- */
  .hero {
    padding-top: clamp(2rem, 5vw, 3.5rem);
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
    transition: gap 0.25s var(--ease-out), color 0.25s var(--ease-out);
  }

  .back:hover {
    color: var(--text-primary);
    gap: 0.75rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .tags-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
  }

  .platform,
  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: 0.35rem 0.75rem;
    color: var(--text-secondary);
  }

  .platform {
    border-color: color-mix(in srgb, var(--card-accent) 40%, var(--border));
    color: color-mix(in srgb, var(--card-accent) 65%, var(--text-primary));
  }

  .status .dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--card-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--card-accent) 18%, transparent);
  }

  .title {
    font-size: clamp(2.75rem, 7vw, 5rem);
    margin: 0 0 0.4rem;
  }

  .subtitle {
    color: var(--card-accent);
    font-weight: 650;
    font-size: 1.15rem;
    margin: 0 0 1.25rem;
  }

  .lead {
    max-width: 34rem;
    margin: 0;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .hero-links a {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid var(--border-strong);
    padding-bottom: 0.15rem;
  }

  .hero-links a:hover {
    border-color: var(--card-accent);
  }

  .visual-inner {
    border-radius: 1rem;
    overflow: hidden;
  }

  /* Narrative --------------------------------------------------------------- */
  .draw-rule {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .narrative-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
  }

  .block .eyebrow {
    margin-bottom: 1rem;
  }

  .narrative-grid p {
    font-size: clamp(1.15rem, 1.8vw, 1.4rem);
    line-height: 1.6;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin: 0;
    max-width: 34ch;
  }

  /* Features ---------------------------------------------------------------- */
  .feat-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .feat-head .eyebrow {
    margin-bottom: 0.9rem;
  }

  .feat-head h2 {
    margin: 0;
    max-width: 18ch;
  }

  .feat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--border);
  }

  .feat-list li {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: clamp(1rem, 2.5vw, 1.5rem) 0;
    border-bottom: 1px solid var(--border);
    transition: padding-left 0.35s var(--ease-out);
  }

  .feat-list li:hover {
    padding-left: 0.75rem;
  }

  .feat-index {
    color: var(--card-accent);
    font-variant-numeric: tabular-nums;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .feat-text {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    letter-spacing: -0.02em;
  }

  /* Meta -------------------------------------------------------------------- */
  .meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    padding-top: clamp(3rem, 6vw, 4rem);
    border-top: 1px solid var(--border);
  }

  .principles {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .principles li {
    font-size: clamp(1.25rem, 2.5vw, 1.85rem);
    letter-spacing: -0.02em;
    padding: 0.6rem 0;
    color: var(--text-primary);
  }

  .principles li::before {
    content: "";
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    margin-right: 0.85rem;
    border-radius: 50%;
    background: var(--card-accent);
    vertical-align: middle;
  }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech span {
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 99px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: border-color 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }

  .tech span:hover {
    border-color: color-mix(in srgb, var(--card-accent) 45%, var(--border));
    color: var(--text-primary);
  }

  /* Closing ----------------------------------------------------------------- */
  .status-band {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    padding: clamp(2rem, 4vw, 3rem);
    border: 1px solid var(--border);
    border-radius: 1.1rem;
    background: var(--surface);
    overflow: hidden;
  }

  .status-band .eyebrow {
    margin-bottom: 0.75rem;
  }

  .status-line {
    margin: 0;
    max-width: 42ch;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    font-weight: 650;
    text-decoration: none;
    color: var(--text-primary);
  }

  .cta span {
    color: var(--card-accent);
    transition: transform 0.25s var(--ease-out);
  }

  .cta:hover span {
    transform: translateX(4px);
  }

  .all-projects {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: gap 0.25s var(--ease-out), color 0.25s var(--ease-out);
  }

  .all-projects:hover {
    color: var(--text-primary);
    gap: 0.75rem;
  }

  /* Responsive -------------------------------------------------------------- */
  @media (max-width: 820px) {
    .hero-grid,
    .narrative-grid,
    .meta-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      order: -1;
    }

    .narrative-grid p {
      max-width: none;
    }
  }

  @media (max-width: 560px) {
    .status-band {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
