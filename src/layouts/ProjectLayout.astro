---
import BaseLayout from './BaseLayout.astro'; import ProjectStatus from '../components/ProjectStatus.astro'; import ProductPreview from '../components/ProductPreview.astro'; import type { Project } from '../data/projects';
interface Props { project: Project; problem: string; solution: string; }
const { project, problem, solution } = Astro.props;
---
<BaseLayout title={`${project.name} — Ward Khleif`} description={project.shortDescription}>
  <section class="project-hero"><div class="shell"><a class="back" href="/projects">← Back to projects</a><div class="project-grid" style={`--card-accent:${project.accent}`}><div><ProjectStatus status={project.status}/><p class="eyebrow">{project.platform}</p><h1>{project.name}</h1>{project.subtitle && <p class="subtitle">{project.subtitle}</p>}<p class="lead">{project.shortDescription}</p><p class="development">Currently in development</p></div><ProductPreview type={project.preview}/></div></div></section>
  <section><div class="shell detail-grid"><div data-reveal><p class="eyebrow">The problem</p><h2>Making the hard part feel manageable.</h2><p>{problem}</p></div><div data-reveal><p class="eyebrow">The solution</p><h2>A focused path forward.</h2><p>{solution}</p></div></div></section>
  <section><div class="shell columns"><div data-reveal><p class="eyebrow">Key features</p><h2>Designed around the real workflow.</h2><ul>{project.features?.map(feature=><li>{feature}</li>)}</ul></div><div data-reveal><p class="eyebrow">Product principles</p><h2>Care in the details.</h2><ul>{project.principles?.map(principle=><li>{principle}</li>)}</ul><h3>Technology</h3><div class="tags">{project.technologies.map(tech=><span>{tech}</span>)}</div></div></div></section>
  <section><div class="shell status-panel" data-reveal><div><p class="eyebrow">Development status</p><h2>Currently in development</h2><p>This product is being prepared thoughtfully for its first public release. No availability or approval is implied yet.</p></div><a href="/projects">Explore all projects <span aria-hidden="true">→</span></a></div></section>
</BaseLayout>
<style>.project-hero{padding:4rem 0 5rem}.back{display:inline-block;color:var(--text-secondary);margin-bottom:2.5rem;text-decoration:none}.project-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,6vw,6rem);align-items:center}.project-grid h1{font-size:clamp(2.8rem,7vw,5.5rem);margin:.7rem 0 .3rem}.subtitle{color:var(--card-accent);font-weight:650;font-size:1.2rem}.lead{color:var(--text-secondary);font-size:1.15rem;max-width:38rem;line-height:1.7}.development{font-size:.9rem}.detail-grid,.columns{display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,7vw,7rem);padding-top:5rem;padding-bottom:5rem;border-top:1px solid var(--border)}.detail-grid p,.columns li,.status-panel p{color:var(--text-secondary);line-height:1.75}.columns ul{list-style:none;padding:0}.columns li{padding:.7rem 0;border-bottom:1px solid var(--border)}.columns li:before{content:'↗';color:var(--card-accent);margin-right:.65rem}.columns h3{margin-top:2.5rem}.tags{display:flex;flex-wrap:wrap;gap:.5rem}.tags span{padding:.45rem .65rem;border:1px solid var(--border);border-radius:99px;font-size:.8rem;color:var(--text-secondary)}.status-panel{padding-top:4rem;padding-bottom:4rem;border:1px solid var(--border);background:var(--surface);border-radius:1rem;display:flex;align-items:end;justify-content:space-between;gap:2rem;padding-left:clamp(1.5rem,5vw,4rem);padding-right:clamp(1.5rem,5vw,4rem)}.status-panel div{max-width:40rem}.status-panel a{white-space:nowrap}@media(max-width:750px){.project-grid,.detail-grid,.columns{grid-template-columns:1fr}.project-grid :global(.preview){order:-1}.status-panel{align-items:start;flex-direction:column}}</style>
